## 🎨 GUÍAS DE ESTILO Y ARQUITECTURA

### 1. Estructura de Archivos

```
app/
  ├── (auth)/           # Rutas de autenticación
  ├── (dashboard)/      # Rutas protegidas
  ├── api/              # API Routes
  │   ├── [resource]/
  │   │   ├── route.ts           # GET, POST
  │   │   └── [id]/route.ts      # GET, PUT, DELETE
  │   └── auth/[...nextauth]/route.ts
  ├── layout.tsx
  └── page.tsx

components/
  ├── ui/               # Componentes Shadcn
  ├── layout/           # Header, Footer, Sidebar
  ├── [feature]/        # Componentes por feature
  └── shared/           # Componentes reutilizables

lib/
  ├── [service].ts      # Servicios de negocio
  ├── db.ts             # Prisma Client
  ├── auth-options.ts   # NextAuth config
  ├── utils.ts          # Utilidades
  └── validations/      # Schemas Zod/Yup

types/
  ├── [feature].d.ts    # Tipos por feature
  └── prisma-types.ts   # Re-exports de Prisma
```

### 2. Convenciones de Código

#### Nombres de Archivos
- **Componentes React**: `PascalCase.tsx` → `UserProfile.tsx`
- **API Routes**: `route.ts` (Next.js 15 App Router)
- **Utilities/Services**: `kebab-case.ts` → `auth-service.ts`
- **Hooks**: `useCamelCase.ts` → `useUserProfile.ts`
- **Types**: `kebab-case.d.ts` → `user-types.d.ts`

#### Imports
```typescript
// ✅ ORDEN CORRECTO DE IMPORTS:
// 1. React/Next.js
import { useState } from 'react';
import { NextRequest, NextResponse } from 'next/server';

// 2. Librerías externas
import { z } from 'zod';
import { toast } from 'sonner';

// 3. Alias internos (@/)
import { prisma } from '@/lib/db';
import { Button } from '@/components/ui/button';

// 4. Relativos (si es necesario)
import { helper } from './utils';

// 5. Types (al final)
import type { User } from '@/types/prisma-types';
```

### 3. Patrones de Componentes React

#### Server Components (por defecto)
```typescript
// ✅ app/dashboard/page.tsx
import { prisma } from '@/lib/db';

export default async function DashboardPage() {
  // Fetch directo en Server Component
  const users = await prisma.user.findMany();
  
  return <div>{/* Renderizar */}</div>;
}
```

#### Client Components (cuando sea necesario)
```typescript
// ✅ components/UserForm.tsx
'use client'; // Obligatorio para hooks, eventos, state

import { useState } from 'react';
import { useForm } from 'react-hook-form';

export function UserForm() {
  const [loading, setLoading] = useState(false);
  const form = useForm();
  
  return <form>{/* Form */}</form>;
}
```

#### Optimización con Dynamic Imports
```typescript
// ✅ app/admin/page.tsx
import dynamic from 'next/dynamic';

// Lazy load de componentes pesados
const AdminChart = dynamic(() => import('@/components/AdminChart'), {
  loading: () => <p>Cargando gráfico...</p>,
  ssr: false, // No renderizar en servidor
});
```

### 4. API Routes Pattern

```typescript
// ✅ app/api/users/route.ts
import { NextRequest, NextResponse } from 'next/server';
import { getServerSession } from 'next-auth';
import { authOptions } from '@/lib/auth-options';
import { prisma } from '@/lib/db';
import { z } from 'zod';

// CRÍTICO: Marcar como dinámico
export const dynamic = 'force-dynamic';

// Schema de validación
const createUserSchema = z.object({
  email: z.string().email(),
  name: z.string().min(2),
});

export async function GET(request: NextRequest) {
  try {
    // 1. Autenticación
    const session = await getServerSession(authOptions);
    if (!session) {
      return NextResponse.json(
        { error: 'No autenticado' },
        { status: 401 }
      );
    }

    // 2. Rate limiting (si aplica)
    // const rateLimitResult = await rateLimit(request);

    // 3. Lógica de negocio
    const users = await prisma.user.findMany({
      where: { companyId: session.user.companyId },
      take: 100,
    });

    // 4. Respuesta
    return NextResponse.json({ users });
  } catch (error: any) {
    console.error('[API Error]:', error);
    return NextResponse.json(
      { error: 'Error interno del servidor' },
      { status: 500 }
    );
  }
}

export async function POST(request: NextRequest) {
  try {
    const session = await getServerSession(authOptions);
    if (!session) {
      return NextResponse.json(
        { error: 'No autenticado' },
        { status: 401 }
      );
    }

    // Validación
    const body = await request.json();
    const validatedData = createUserSchema.parse(body);

    // Lógica
    const user = await prisma.user.create({
      data: {
        ...validatedData,
        companyId: session.user.companyId,
      },
    });

    return NextResponse.json(user, { status: 201 });
  } catch (error: any) {
    if (error instanceof z.ZodError) {
      return NextResponse.json(
        { error: 'Datos inválidos', details: error.errors },
        { status: 400 }
      );
    }
    
    console.error('[API Error]:', error);
    return NextResponse.json(
      { error: 'Error interno del servidor' },
      { status: 500 }
    );
  }
}
```

### 5. Server Actions Pattern

```typescript
// ✅ app/actions/user-actions.ts
'use server';

import { revalidatePath } from 'next/cache';
import { prisma } from '@/lib/db';
import { getServerSession } from 'next-auth';
import { authOptions } from '@/lib/auth-options';

export async function createUser(formData: FormData) {
  // Autenticación
  const session = await getServerSession(authOptions);
  if (!session) {
    throw new Error('No autenticado');
  }

  // Validación
  const email = formData.get('email') as string;
  const name = formData.get('name') as string;

  if (!email || !name) {
    throw new Error('Campos requeridos');
  }

  // Lógica
  const user = await prisma.user.create({
    data: { email, name, companyId: session.user.companyId },
  });

  // Revalidar cache
  revalidatePath('/dashboard/users');

  return user;
}
```

### 6. Manejo de Errores

```typescript
// ✅ components/ErrorBoundary.tsx (ya existe)
'use client';

import { useEffect } from 'react';

export default function ErrorBoundary({
  error,
  reset,
}: {
  error: Error & { digest?: string };
  reset: () => void;
}) {
  useEffect(() => {
    // Log a Sentry
    console.error('Error capturado:', error);
  }, [error]);

  return (
    <div>
      <h2>Algo salió mal</h2>
      <button onClick={reset}>Reintentar</button>
    </div>
  );
}
```

### 7. Prisma Best Practices

```typescript
// ✅ SIEMPRE usar tipos importados de @/types/prisma-types
// NO importar directamente de @prisma/client en APIs
import type { User, UserRole } from '@/types/prisma-types';

// ✅ Usar transacciones para operaciones múltiples
await prisma.$transaction(async (tx) => {
  const user = await tx.user.create({ ... });
  await tx.auditLog.create({ ... });
});

// ✅ Usar select para optimizar queries
const users = await prisma.user.findMany({
  select: {
    id: true,
    email: true,
    name: true,
    // No traer password u otros campos sensibles
  },
});

// ✅ Implementar paginación
const users = await prisma.user.findMany({
  skip: (page - 1) * limit,
  take: limit,
  orderBy: { createdAt: 'desc' },
});
```

### 8. TypeScript Guidelines

```typescript
// ✅ Usar tipos explícitos en funciones públicas
export async function getUser(id: string): Promise<User | null> {
  return await prisma.user.findUnique({ where: { id } });
}

// ✅ Usar Zod para validación runtime + tipos
const userSchema = z.object({
  email: z.string().email(),
  name: z.string(),
});

type UserInput = z.infer<typeof userSchema>; // Tipo inferido

// ✅ Usar type guards
function isAdmin(user: User): user is User & { role: 'ADMIN' } {
  return user.role === 'ADMIN';
}

// ✅ Usar utility types de TypeScript
type PartialUser = Partial<User>;
type RequiredUser = Required<User>;
type UserWithoutPassword = Omit<User, 'password'>;
```

### 9. Accesibilidad (a11y)

```typescript
// ✅ Shadcn ya incluye accesibilidad, pero verifica:
<Button
  aria-label="Cerrar modal"
  aria-pressed={isActive}
  disabled={loading}
>
  Acción
</Button>

// ✅ Usar semantic HTML
<main>
  <article>
    <header>
      <h1>Título</h1>
    </header>
    <section>
      <p>Contenido</p>
    </section>
  </article>
</main>

// ✅ Focus management
<Dialog>
  <DialogTrigger asChild>
    <Button>Abrir</Button>
  </DialogTrigger>
  <DialogContent> {/* Radix maneja focus automáticamente */}
    <DialogTitle>Título</DialogTitle>
  </DialogContent>
</Dialog>
```

### 10. Performance & SEO

```typescript
// ✅ Metadata en Server Components
import { Metadata } from 'next';

export const metadata: Metadata = {
  title: 'Dashboard | Inmova',
  description: 'Panel de control',
};

// ✅ Loading states
// app/dashboard/loading.tsx
export default function Loading() {
  return <Skeleton />;
}

// ✅ Suspense para streaming
import { Suspense } from 'react';

export default function Page() {
  return (
    <Suspense fallback={<Loading />}>
      <HeavyComponent />
    </Suspense>
  );
}

// ✅ Imagen optimizada
import Image from 'next/image';

<Image
  src="/logo.png"
  alt="Logo de Inmova"
  width={200}
  height={100}
  priority // Para above-the-fold
/>
```

