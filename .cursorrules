// Plantillas de email
const EMAIL_TEMPLATES = {
  WELCOME: {
    subject: '¡Bienvenido a Inmova! 🏠',
    template: (userName: string) => `
      <h1>¡Hola ${userName}!</h1>
      <p>Estamos encantados de tenerte en Inmova.</p>
      <h2>Próximos pasos:</h2>
      <ol>
        <li>Completa tu perfil</li>
        <li>Crea tu primera propiedad</li>
        <li>Explora el dashboard</li>
      </ol>
      <a href="https://inmovaapp.com/dashboard">Ir al Dashboard</a>
    `,
  },
  PROPERTY_CREATED: {
    subject: '✅ Propiedad creada exitosamente',
    template: (propertyName: string) => `
      <p>Tu propiedad <strong>${propertyName}</strong> ha sido creada.</p>
      <p>Ahora puedes:</p>
      <ul>
        <li>Publicarla para buscar inquilinos</li>
        <li>Crear un contrato</li>
        <li>Subir documentos</li>
      </ul>
    `,
  },
  // ... más plantillas
};

// Worker de emails (BullMQ)
export async function processEmailJob(job: Job) {
  const { type, userId, data } = job.data;
  
  const user = await prisma.user.findUnique({ where: { id: userId } });
  const template = EMAIL_TEMPLATES[type];
  
  await transporter.sendMail({
    from: '"Inmova App" <noreply@inmovaapp.com>',
    to: user.email,
    subject: template.subject,
    html: template.template(user.name, ...data),
  });
}
```

### 📱 4. Mobile First CSS Rules

```css
/* 📁 styles/mobile-first.css */

/* REGLA #1: Base styles para móvil (< 640px) */
.container {
  padding: 1rem;
  max-width: 100%;
}

.button {
  width: 100%;
  min-height: 44px; /* Mínimo para tocar con dedo */
  font-size: 16px; /* Evitar zoom en iOS */
}

/* REGLA #2: Touch targets mínimo 44x44px */
.clickable {
  min-width: 44px;
  min-height: 44px;
  padding: 12px;
}

/* REGLA #3: Formularios optimizados para móvil */
input, select, textarea {
  font-size: 16px; /* Evitar zoom automático en iOS */
  width: 100%;
  padding: 12px;
}

/* REGLA #4: Navegación bottom para móvil */
.mobile-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 64px;
  background: white;
  border-top: 1px solid #e5e7eb;
  display: flex;
  justify-content: space-around;
  align-items: center;
  z-index: 50;
}

/* REGLA #5: Ocultar sidebar en móvil */
.desktop-sidebar {
  display: none;
}

/* REGLA #6: Tablet (sm: 640px+) */
@media (min-width: 640px) {
  .container {
    padding: 1.5rem;
  }
  
  .button {
    width: auto;
  }
}

/* REGLA #7: Desktop (lg: 1024px+) */
@media (min-width: 1024px) {
  .mobile-nav {
    display: none;
  }
  
  .desktop-sidebar {
    display: block;
  }
  
  .container {
    max-width: 1280px;
    margin: 0 auto;
  }
}

/* REGLA #8: Gestos táctiles */
.swipeable {
  touch-action: pan-y; /* Permitir scroll vertical, bloquear horizontal */
  -webkit-overflow-scrolling: touch; /* Smooth scroll en iOS */
}

/* REGLA #9: Safe areas para móviles con notch */
.safe-area-top {
  padding-top: env(safe-area-inset-top);
}

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* REGLA #10: Optimizar rendimiento */
.gpu-accelerated {
  transform: translateZ(0);
  will-change: transform;
}
```

