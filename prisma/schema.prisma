// ============================================================================
// VALORACIÓN AUTOMÁTICA DE PROPIEDADES CON IA
// ============================================================================

enum PropertyCondition {
  NEW
  EXCELLENT
  GOOD
  FAIR
  NEEDS_RENOVATION
  POOR
}

enum MarketTrend {
  UP
  STABLE
  DOWN
}

model PropertyValuation {
  id        String  @id @default(cuid())
  companyId String
  unitId    String? // Opcional: puede ser valoración de propiedad no ingresada

  // Input features - Características de la propiedad
  address      String
  postalCode   String
  city         String
  province     String?
  neighborhood String?
  squareMeters Float
  rooms        Int
  bathrooms    Int
  floor        Int?
  hasElevator  Boolean           @default(false)
  hasParking   Boolean           @default(false)
  hasGarden    Boolean           @default(false)
  hasPool      Boolean           @default(false)
  hasTerrace   Boolean           @default(false)
  hasGarage    Boolean           @default(false)
  condition    PropertyCondition @default(GOOD)
  yearBuilt    Int?

  // Market data - Datos del mercado
  avgPricePerM2 Float?
  marketTrend   MarketTrend?
  comparables   Json? // Array de propiedades similares

  // Output - Resultado de la valoración
  estimatedValue  Float // Precio estimado
  confidenceScore Float // 0-100
  minValue        Float // Rango mínimo
  maxValue        Float // Rango máximo
  pricePerM2      Float? // Precio por m² calculado

  // IA Details
  model      String // "claude-3-5-sonnet", "gpt-4", etc.
  reasoning  String?  @db.Text // Explicación de la valoración
  keyFactors String[] @default([]) // Factores clave que influyeron

  // ROI & Investment
  estimatedRent Float? // Renta mensual estimada
  estimatedROI  Float? // ROI anual estimado (%)
  capRate       Float? // Capitalization rate

  // Recommendations
  recommendations String[] @default([]) // Recomendaciones para mejorar valor

  // Metadata
  requestedBy String // User ID
  ipAddress   String?
  userAgent   String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  company Company @relation("CompanyPropertyValuations", fields: [companyId], references: [id], onDelete: Cascade)
  unit    Unit?   @relation("UnitPropertyValuations", fields: [unitId], references: [id], onDelete: SetNull)
  user    User    @relation("UserPropertyValuations", fields: [requestedBy], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([unitId])
  @@index([requestedBy])
  @@index([city])
  @@index([postalCode])
  @@index([createdAt])
  @@map("property_valuations")
}

// ============================================================================
// CACHE DE DATOS DE MERCADO DE PLATAFORMAS EXTERNAS
// ============================================================================

model ExternalMarketDataCache {
  id String @id @default(cuid())

  // Ubicación
  city         String
  postalCode   String?
  province     String?
  neighborhood String?

  // Fuente
  source      String // 'idealista', 'fotocasa', 'habitaclia', 'notariado', 'ine'
  sourceLabel String?
  dataType    String // 'asking_price', 'transaction_price', 'index', 'estimate'

  // Datos de precios
  pricePerM2Sale Float?
  pricePerM2Rent Float?
  avgPrice       Float?
  sampleSize     Int?

  // Tendencia
  trend           String? // 'UP', 'STABLE', 'DOWN'
  trendPercentage Float?
  demandLevel     String? // 'alta', 'media', 'baja'
  avgDaysOnMarket Int?

  // Comparables encontrados
  comparables Json?

  // Fiabilidad
  reliability Int @default(0) // 0-100

  // Datos crudos de la API
  rawData Json?

  // TTL
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city, postalCode, source])
  @@index([expiresAt])
  @@index([source])
  @@map("external_market_data_cache")
}

// ============================================================================
// FIRMA DIGITAL DE CONTRATOS
// ============================================================================

enum SignatureStatus {
  PENDING
  SIGNED
  DECLINED
  EXPIRED
  CANCELLED
}

enum SignatureProvider {
  DOCUSIGN
  SIGNATURIT
  SELF_HOSTED
}

model ContractSignature {
  id         String @id @default(cuid())
  companyId  String
  contractId String // ID del contrato a firmar

  // Proveedor de firma
  provider   SignatureProvider @default(SIGNATURIT)
  externalId String? // ID en sistema externo (DocuSign/Signaturit)

  // Documento
  documentUrl  String // URL del PDF del contrato
  documentName String
  documentHash String? // SHA-256 hash para verificación

  // Firmantes (signatories)
  signatories Json // Array de firmantes: [{ name, email, role, status, signedAt }]

  // Estado
  status SignatureStatus @default(PENDING)

  // URLs
  signingUrl   String? @db.Text // URL para firmar (DocuSign/Signaturit)
  completedUrl String? @db.Text // URL del documento firmado

  // Notificaciones
  emailSubject  String?
  emailMessage  String? @db.Text
  remindersSent Int     @default(0)

  // Fechas
  sentAt      DateTime?
  expiresAt   DateTime?
  completedAt DateTime?

  // Metadata
  ipAddress   String?
  userAgent   String? @db.Text
  requestedBy String // User ID

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  company  Company  @relation("CompanyContractSignatures", fields: [companyId], references: [id], onDelete: Cascade)
  contract Contract @relation("ContractSignatures", fields: [contractId], references: [id], onDelete: Cascade)
  user     User     @relation("UserContractSignatures", fields: [requestedBy], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([contractId])
  @@index([status])
  @@index([provider])
  @@index([expiresAt])
  @@map("contract_signatures")
}

model SignatureWebhook {
  id          String            @id @default(cuid())
  signatureId String
  provider    SignatureProvider

  // Evento
  event           String // 'signature_completed', 'signature_declined', 'reminder_sent', etc.
  externalEventId String?

  // Payload
  rawPayload Json

  // Procesamiento
  processed    Boolean   @default(false)
  processedAt  DateTime?
  errorMessage String?   @db.Text

  createdAt DateTime @default(now())

  @@index([signatureId])
  @@index([provider])
  @@index([event])
  @@index([processed])
  @@map("signature_webhooks")
}

// ============================================================================
// SOLICITUDES DE FIRMA DE OPERADORES (Álamo, etc.)
// ============================================================================

enum OperatorSignatureStatus {
  pending_review // Recibido, pendiente de revisión
  approved // Aprobado, listo para enviar a firma
  sent_to_sign // Enviado a DocuSign/Signaturit
  signed // Firmado por todas las partes
  rejected // Rechazado por el gestor
  expired // Expirado sin firmar
  cancelled // Cancelado
}

model OperatorSignatureRequest {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation("CompanyOperatorSignatures", fields: [companyId], references: [id], onDelete: Cascade)

  // Operador de media estancia
  operatorName  String // "Álamo", "Spotahome", "HousingAnywhere", etc.
  operatorEmail String?
  operatorPhone String?
  operatorRef   String? // Referencia interna del operador

  // Documento a firmar
  documentUrl  String  @db.Text // URL del PDF en S3
  documentName String
  documentHash String? // SHA-256

  // Asociación con unidad/contrato
  unitId     String?
  unit       Unit?     @relation("UnitOperatorSignatures", fields: [unitId], references: [id], onDelete: SetNull)
  contractId String?
  contract   Contract? @relation("ContractOperatorSignatures", fields: [contractId], references: [id], onDelete: SetNull)
  buildingId String?

  // Datos del inquilino (proporcionados por el operador)
  tenantName  String?
  tenantEmail String?
  tenantPhone String?
  tenantDni   String?

  // Firmantes propuestos
  signatories Json // [{ name, email, role, phone? }]

  // Detalles del contrato
  contractType String? // "media_estancia", "temporada", "corporativo"
  startDate    DateTime?
  endDate      DateTime?
  monthlyRent  Float?
  currency     String    @default("EUR")

  // Workflow de aprobación
  status         OperatorSignatureStatus @default(pending_review)
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewNotes    String?                 @db.Text
  rejectedReason String?                 @db.Text

  // Enlace con firma digital (cuando se envía a DocuSign/Signaturit)
  signatureId         String? // ID del ContractSignature
  signatureProvider   String? // "DOCUSIGN" | "SIGNATURIT"
  signatureExternalId String? // Envelope ID / Signaturit ID
  signatureUrl        String? @db.Text

  // Cómo se recibió
  receivedVia String @default("manual") // "manual", "email", "api", "webhook"

  // Firma en lote
  batchId String? // Para agrupar múltiples firmas

  // Timestamps
  sentToSignAt DateTime?
  signedAt     DateTime?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([companyId])
  @@index([operatorName])
  @@index([status])
  @@index([unitId])
  @@index([contractId])
  @@index([batchId])
  @@index([createdAt])
  @@map("operator_signature_requests")
}

// ============================================================================
// MATCHING AUTOMÁTICO INQUILINO-PROPIEDAD
