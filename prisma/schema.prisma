  alquiler
  seguro
  hipoteca
}

enum PortalTipo {
  idealista
  fotocasa
  habitaclia
  pisos_com
  yaencontre
  custom
}

enum PublicacionEstado {
  borrador
  activa
  pausada
  expirada
  eliminada
}

enum ScreeningEstado {
  pendiente
