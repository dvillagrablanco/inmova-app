model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String
  password         String
  role             UserRole          @default(gestor)
  companyId        String
  activo           Boolean           @default(true)
  businessVertical BusinessVertical?
  setupProgress    String? // JSON string con las acciones completadas del onboarding
  resetToken       String?           @unique
  resetTokenExpiry DateTime?
  recoveryEmail    String? // Email alternativo para recuperación de contraseña

  // Multi-Factor Authentication (MFA)
  mfaEnabled       Boolean   @default(false)
  mfaSecret        String? // Encrypted TOTP secret
  mfaBackupCodes   String[]  @default([]) // Encrypted backup codes
  mfaVerifiedAt    DateTime?
  mfaRecoveryCodes Int       @default(10) // Count of remaining codes

  // Zero-Touch Onboarding - User Profile
  experienceLevel        ExperienceLevel? @default(intermedio)
  techSavviness          TechSavviness?   @default(medio)
  portfolioSize          PortfolioSize?   @default(size_1_5)
  uiMode                 UIMode           @default(standard)
  onboardingCompleted    Boolean          @default(false)
  hasCompletedOnboarding Boolean          @default(false)
  onboardingCompletedAt  DateTime?
  preferredModules       String[]         @default([]) // IDs de módulos favoritos
  hiddenModules          String[]         @default([]) // IDs de módulos ocultados
  lastAction             String? // Última acción realizada

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company              Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  notifications        Notification[]
  tasksAsignadas       Task[]                   @relation("TaskAssignedTo")
  tasksCreadas         Task[]                   @relation("TaskCreatedBy")
  auditLogs            AuditLog[]
  preferences          UserPreference?
  securityEvents       SecurityEvent[]
  chatbotConversations ChatbotConversation[]
  documentosCreados    DocumentoFirma[]         @relation("DocumentosCreados")
  dashboardPreference  UserDashboardPreference?
  dashboardWidgets     DashboardWidget[]
  searchHistory        SearchHistory[]
  savedSearches        SavedSearch[]

  // Nuevos Módulos Estratégicos Fase 2
  aiConversations        AIConversation[]        @relation("UserAIConversations")
  voiceInteractions      VoiceInteraction[]      @relation("UserVoiceInteractions")
  biometricVerifications BiometricVerification[] @relation("UserBiometricVerifications")
  gdprConsents           GDPRConsent[]           @relation("UserGDPRConsents")

  // Multi-empresa
  companyAccess UserCompanyAccess[]

  // Sugerencias
  suggestions Suggestion[]

  // CRM - Leads
  leadsAsignados  Lead[]
  actividadesLead LeadActivity[]
  documentosLead  LeadDocument[]

  // Push Notifications
  pushSubscriptions PushSubscription[]

  // Bank Connections
  bankConnections BankConnection[]

  // Automatización de onboarding y soporte
  onboardingProgress OnboardingProgress[]
  supportTickets     SupportTicket[]

  // Portal Inquilino - Mejoras Críticas
  tenantInvitations TenantInvitation[]

  // Sistema de Automatizaciones Inteligentes
  automations Automation[]

  // Sistema de Notificaciones Avanzado - Fase 2
  notificationLogs         NotificationLog[]
  userNotificationSettings UserNotificationSettings?

  // Soporte e interacciones de ayuda
  supportInteractions SupportInteraction[]

  // Workflows creados por el usuario
  createdWorkflows Workflow[]

  // Emails programados (sistema de automatización)
  scheduledEmails ScheduledEmail[]

  // Zero-Touch Onboarding System
  onboardingTasks     OnboardingTask[]
  moduleUsageStats    ModuleUsageStats[]
  inAppNotifications  InAppNotification[]
  emailLogs           EmailLog[]
  chatbotInteractions ChatbotInteraction[]
  userCelebrations    UserCelebration[]

  // CRM Avanzado - Comentado temporalmente
  // ownedLeads            CRMLead[]       @relation("LeadOwner")
  // ownedDeals            Deal[]          @relation("DealOwner")
  // crmActivities         CRMActivity[]   @relation("ActivityPerformer")
  // assignedCRMTasks      CRMTask[]       @relation("TaskAssignee")
  pomelliPosts PomelliSocialPost[]

  // Nuevas funcionalidades IA (Valoración, Firma Digital)
  propertyValuations PropertyValuation[] @relation("UserPropertyValuations")
  contractSignatures ContractSignature[] @relation("UserContractSignatures")

  // Partner Program
  partnerAccount Partner?

  // API & Integrations Ecosystem
  createdApiKeys              ApiKey[]
  createdWebhookSubscriptions WebhookSubscription[]
  oauthAuthorizationCodes     OAuthAuthorizationCode[]
  oauthAccessTokens           OAuthAccessToken[]

  // Tutorial & Setup Progress
  onboardingProgressDetailed UserOnboardingProgress?

  // eWoorker Chat
  ewoorkerConversacionesParticipante EwoorkerParticipanteConversacion[]

  // 📄 ONBOARDING DOCUMENTAL CON IA
  documentImportBatches      DocumentImportBatch[]
  onboardingDocumentSessions OnboardingDocumentSession[]

  @@index([email])
  @@index([companyId])
  @@index([role, companyId])
  @@index([activo])
  @@index([createdAt])
  @@map("users")
}

model Building {
  id                    String       @id @default(cuid())
  companyId             String
  nombre                String
  direccion             String
  tipo                  BuildingType
  referenciaCatastral   String? // Ref catastral principal del edificio (ej: 0858104VK4705H)
  anoConstructor        Int
  numeroUnidades        Int
  estadoConservacion    String?
  certificadoEnergetico String?
  ascensor              Boolean      @default(false)
  garaje                Boolean      @default(false)
  trastero              Boolean      @default(false)
  piscina               Boolean      @default(false)
  jardin                Boolean      @default(false)
  gastosComunidad       Float?
  ibiAnual              Float?
  latitud               Float?
  longitud              Float?
  imagenes              String[]     @default([])
  etiquetas             String[]     @default([])
  isDemo                Boolean      @default(false) // Marca datos de demostración - excluir de estadísticas
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  company                Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  units                  Unit[]
  expenses               Expense[]
  documents              Document[]
  maintenanceSchedules   MaintenanceSchedule[]
  serviceQuotes          ServiceQuote[]
  serviceJobs            ServiceJob[]
  energyReadings         EnergyReading[]
  energyAlerts           EnergyAlert[]
  insurancePolicies      InsurancePolicy[]
  insuranceQuoteRequests InsuranceQuoteRequest[]

  // Prioridades Medias
  valoraciones  ValoracionPropiedad[]
  publicaciones PublicacionPortal[]

  // Sociedades Inversoras
  assetAcquisitions AssetAcquisition[]

  // Fase 1
  calendarEvents CalendarEvent[]

  // Fase 2
  commonSpaces CommonSpace[]
  insurances   Insurance[]

  // Fase 3
  communityIncidents     CommunityIncident[]
  communityVotes         CommunityVote[]
  communityAnnouncements CommunityAnnouncement[]
  communityMeetings      CommunityMeeting[]
  providerWorkOrders     ProviderWorkOrder[]

  // Nuevos Módulos Estratégicos
  iotDevices           IoTDevice[]           @relation("BuildingIoTDevices")
  virtualTours         VirtualTour[]         @relation("BuildingVirtualTours")
  carbonFootprints     CarbonFootprint[]     @relation("BuildingCarbonFootprints")
  decarbonizationPlans DecarbonizationPlan[] @relation("BuildingDecarbonizationPlans")
  esgCertifications    ESGCertification[]    @relation("BuildingESGCertifications")

  // Nuevos Módulos Estratégicos Fase 2
  propertyTokens  PropertyToken[]  @relation("BuildingPropertyTokens")
  nftCertificates NFTCertificate[] @relation("BuildingNFTCertificates")

  urbanGardens     UrbanGarden[]     @relation("BuildingUrbanGardens")
  recyclingMetrics RecyclingMetric[] @relation("BuildingRecyclingMetrics")

  socialPosts           SocialPost[]     @relation("BuildingSocialPosts")
  communityEventsPhase2 CommunityEvent[] @relation("BuildingCommunityEvents")
  ambassadors           Ambassador[]     @relation("BuildingAmbassadors")

  flippingProjects     FlippingProject[]     @relation
  constructionProjects ConstructionProject[] @relation

  // Portal Propietario - Asignación de Edificios
  ownerBuildings OwnerBuilding[]

  // Gestión de Comunidades
  communityMinutes    CommunityMinute[]
  communityFees       CommunityFee[]
  communityFunds      CommunityFund[]
  financialAlerts     FinancialAlert[]
  cashFlowForecasts   CashFlowForecast[]
  buildingInspections BuildingInspection[]

  // Coliving
  colivingGroups        ColivingGroup[]
  colivingActivityPosts ColivingActivityPost[]
  colivingEvents        ColivingEvent[]
  smartLocks            SmartLock[]
  colivingPackages      ColivingPackage[]
  // Administrador de Fincas
  communityManagement   CommunityManagement?

  // 🏢 Alquiler Comercial - Oficinas, Locales, Naves en este edificio
  commercialSpaces CommercialSpace[] @relation("BuildingCommercialSpaces")

  // Índices optimizados para consultas frecuentes
  @@index([companyId])
  @@index([tipo, companyId])
  @@index([companyId, createdAt])
  @@index([companyId, tipo, anoConstructor]) // Nuevo: búsqueda por tipo y año
  @@map("buildings")
}

model Tenant {
  id                    String            @id @default(cuid())
  companyId             String
  nombreCompleto        String
  dni                   String            @unique
  email                 String            @unique
  telefono              String
  fechaNacimiento       DateTime
  nacionalidad          String?
  estadoCivil           EstadoCivil?
  numeroOcupantes       Int?
  direccionActual       String?
  situacionLaboral      SituacionLaboral?
  empresa               String?
  puesto                String?
  antiguedad            Int?
  ingresosMensuales     Float?
  ratioRentaIngresos    Float?
  scoring               Int               @default(50)
  nivelRiesgo           RiskLevel         @default(medio)
  password              String?
  notas                 String?           @db.Text
  // Integraciones de Contabilidad
  contasimpleCustomerId String?
  isDemo                Boolean           @default(false) // Marca datos de demostración - excluir de estadísticas

  // Datos bancarios y dirección (migration 20260224000000_add_financial_fields)
  iban            String?
  bic             String?
  metodoPago      String?
  personaContacto String?
  ciudad          String?
  codigoPostal    String?
  provincia       String?
  pais            String? @default("España")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company               Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  units                 Unit[]
  contracts             Contract[]
  documents             Document[]
  messagesReceived      Message[]             @relation("MessageRecipient")
  messagesSent          Message[]             @relation("MessageSender")
  stripeCustomer        StripeCustomer?
  documentShares        DocumentShare[]
  chatbotConversations  ChatbotConversation[]
  morosidadPredicciones MorosidadPrediccion[]
  morosidadHistorial    MorosidadHistorial[]
  documentosFirma       DocumentoFirma[]

  // Prioridades Medias
  smsLogs SMSLog[]

  // Fase 1
  calendarEvents  CalendarEvent[]
  bankConnections BankConnection[]

  // Fase 2
  spaceReservations SpaceReservation[]

  // Nuevos Módulos Estratégicos
  marketplaceBookings MarketplaceBooking[] @relation("TenantMarketplaceBookings")
  marketplaceLoyalty  MarketplaceLoyalty?  @relation("TenantMarketplaceLoyalty")

  // Nuevos Módulos Estratégicos Fase 2
  tokenHoldings TokenHolder[] @relation("TenantTokenHoldings")

  aiConversations AIConversation[] @relation("TenantAIConversations")

  circularItems CircularItem[] @relation("TenantCircularItems")
  gardenPlots   GardenPlot[]   @relation("TenantGardenPlots")

  socialPosts    SocialPost[]      @relation("TenantSocialPosts")
  socialComments SocialComment[]   @relation("TenantSocialComments")
  reputation     TenantReputation? @relation("TenantReputation")
  p2pServices    P2PService[]      @relation("TenantP2PServices")
  p2pBookings    P2PBooking[]      @relation("TenantP2PBookings")
  ambassador     Ambassador?       @relation("TenantAmbassador")

  biometricVerifications BiometricVerification[] @relation("TenantBiometricVerifications")
  gdprConsents           GDPRConsent[]           @relation("TenantGDPRConsents")

  // Room Rental Module
  roomContracts RoomContract[]

  // Portal Inquilino - Mejoras Críticas
  invitation          TenantInvitation?
  passwordResetTokens PasswordResetToken[]
  serviceRatings      ServiceRating[]
  onboarding          TenantOnboarding?

  // Nuevas funcionalidades IA (Matching, Preferencias)
  tenantPropertyMatches TenantPropertyMatch[] @relation("TenantMatches")
  tenantPreferences     TenantPreferences?    @relation("TenantPreferences")

  // Coliving
  colivingProfile         ColivingProfile?
  colivingServiceBookings ColivingServiceBooking[]
  colivingCheckInOuts     ColivingCheckInOut[]
  smartLockAccesses       SmartLockAccess[]
  colivingPackages        ColivingPackage[]

  // Coliving - Analytics y Métricas Avanzadas
  npsSurveys         NPSSurvey[]
  tenantProfile      TenantProfile?
  spaceWaitlists     SpaceWaitlist[]
  reservationCredits ReservationCredits?
  spaceRatings       SpaceRating[]

  // Community Management - Pack 1
  eventAttendances          EventAttendee[]
  eventComments             EventComment[]
  postReactions             PostReaction[]
  announcementConfirmations AnnouncementConfirmation[]

  // B2C Gamificación y Referidos
  gamificationPoints       Int                     @default(0)
  gamificationLevel        Int                     @default(1)
  gamificationAchievements Json                    @default("[]")
  loginStreak              Int                     @default(0)
  lastLoginDate            DateTime?
  gamificationLogs         TenantGamificationLog[]
  referralsEnviados        TenantReferral[]        @relation("TenantReferrer")
  referralRecibido         TenantReferral?         @relation("TenantReferred")

  // GoCardless SEPA
  gcCustomer GCCustomer? @relation("TenantGCCustomer")

  // Índices optimizados para consultas frecuentes
  @@index([companyId])
  @@index([email])
  @@index([dni])
  @@index([companyId, scoring])
  @@index([companyId, createdAt]) // Nuevo: tenants por fecha de creación
  @@index([gamificationPoints]) // B2C: Leaderboard
  @@map("tenants")
}

model Unit {
  id                  String     @id @default(cuid())
  numero              String
  buildingId          String
  tipo                UnitType
  estado              UnitStatus @default(disponible)
  superficie          Float
  superficieUtil      Float?
  referenciaCatastral String? // Ref catastral individual de la finca (ej: 0858104VK4705H0001XX)
  precioCompra        Float? // Precio de compra escriturado (proporcional o individual)
  valorMercado        Float? // Última valoración de mercado estimada
  fechaValoracion     DateTime? // Fecha de la última valoración
  habitaciones        Int?
  banos               Int?
  planta              Int?
  orientacion         String?
  rentaMensual        Float
  tenantId            String?
  aireAcondicionado   Boolean    @default(false)
  calefaccion         Boolean    @default(false)
  terraza             Boolean    @default(false)
  balcon              Boolean    @default(false)
  amueblado           Boolean    @default(false)
  gastosComunidad     Float? // Gastos de comunidad mensuales asignados a esta unidad
  ibiAnual            Float? // IBI anual asignado a esta unidad
  imagenes            String[]   @default([])
  tourVirtual         String?
  planos              String[]   @default([])
  isDemo              Boolean    @default(false) // Marca datos de demostración - excluir de estadísticas
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  building             Building              @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  tenant               Tenant?               @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  contracts            Contract[]
  maintenanceRequests  MaintenanceRequest[]
  maintenanceSchedules MaintenanceSchedule[]
  expenses             Expense[]
  documents            Document[]
  candidates           Candidate[]
  serviceQuotes        ServiceQuote[]
  serviceJobs          ServiceJob[]
  energyReadings       EnergyReading[]
  energyAlerts         EnergyAlert[]

  // Prioridades Medias
  valoraciones  ValoracionPropiedad[]
  publicaciones PublicacionPortal[]

  // Sociedades Inversoras
  assetAcquisitions AssetAcquisition[]

  // Fase 1
  calendarEvents CalendarEvent[]

  // Fase 2
  insurances         Insurance[]
  energyCertificates EnergyCertificate[]

  // Fase 3
  communityIncidents CommunityIncident[]
  providerWorkOrders ProviderWorkOrder[]
  propertyGallery    PropertyGallery?

  // Nuevos Módulos Estratégicos
  iotDevices          IoTDevice[]          @relation("UnitIoTDevices")
  virtualTours        VirtualTour[]        @relation("UnitVirtualTours")
  arVisualizations    ARVisualization[]    @relation("UnitARVisualizations")
  marketplaceBookings MarketplaceBooking[] @relation("UnitMarketplaceBookings")
  pricingAnalysis     PricingAnalysis[]    @relation("UnitPricingAnalysis")
  pricingStrategies   PricingStrategy[]    @relation("UnitPricingStrategies")

  // Nuevos Módulos Estratégicos Fase 2
  propertyTokens  PropertyToken[]  @relation("UnitPropertyTokens")
  nftCertificates NFTCertificate[] @relation("UnitNFTCertificates")

  strListings      STRListing[]      @relation
  flippingProjects FlippingProject[] @relation

  // Cuadro de Mandos Financiero
  valuationHistory PropertyValuationHistory[]

  // Room Rental Module
  rooms            Room[]
  roomSharedSpaces RoomSharedSpace[]

  // Gestión de Comunidades
  communityFees            CommunityFee[]
  habitabilityCertificates HabitabilityCertificate[]

  // Coliving
  colivingCheckInOuts ColivingCheckInOut[]
  smartLocks          SmartLock[]

  // Nuevas funcionalidades IA (Valoración, Matching)
  propertyValuations        PropertyValuation[]        @relation("UnitPropertyValuations")
  tenantPropertyMatches     TenantPropertyMatch[]      @relation("UnitTenantMatches")
  operatorSignatureRequests OperatorSignatureRequest[] @relation("UnitOperatorSignatures")

  @@unique([buildingId, numero])
  // Índices optimizados para consultas frecuentes
  @@index([buildingId, estado])
  @@index([estado])
  @@index([tenantId])
  @@index([tipo, estado])
  @@index([buildingId, tipo, estado]) // Nuevo: búsqueda compuesta por edificio, tipo y estado
  @@index([rentaMensual, estado]) // Nuevo: búsqueda por rango de renta
  @@map("units")
}

// ==========================================
// MÓDULO: ALQUILER COMERCIAL
// Oficinas, Locales, Naves Industriales, Coworking
// ==========================================

model CommercialSpace {
  id         String  @id @default(cuid())
  companyId  String
  buildingId String? // Puede estar en un edificio existente

  // Información básica
  nombre      String // "Oficina 3A", "Local 12", etc.
  referencia  String? // Referencia catastral o interna
  tipo        CommercialSpaceType
  descripcion String?             @db.Text

  // Ubicación
  direccion    String
  ciudad       String
  codigoPostal String
  provincia    String
  pais         String  @default("España")
  planta       Int? // Planta del edificio
  puerta       String? // Número o letra de puerta
  latitud      Float?
  longitud     Float?

  // Superficie
  superficieConstruida Float // m² construidos
  superficieUtil       Float // m² útiles
  superficieComunes    Float? // m² de zonas comunes asignadas
  alturaLibre          Float? // Altura libre en metros

  // Características físicas
  fachada                  Boolean @default(false) // Tiene escaparate/fachada a calle
  longitudFachada          Float? // Metros de fachada
  accesoCargaDescarga      Boolean @default(false)
  muelleCarga              Boolean @default(false)
  alturaMuelleCarga        Float? // Altura del muelle en metros
  cargaSuelo               Float? // kg/m² soportados
  plantaDiafana            Boolean @default(false)
  divisible                Boolean @default(false) // Se puede dividir
  superficieMinimaDivision Float? // m² mínimos si es divisible

  // Instalaciones
  potenciaElectrica        Float? // kW contratados/disponibles
  potenciaMaximaDisponible Float? // kW máximos instalables
  tipoCorreinte            String? // "Monofásica", "Trifásica", "Ambas"
  aireAcondicionado        Boolean @default(false)
  tipoClimatizacion        String? // "Central", "Split", "VRV", "Sin climatización"
  calefaccion              Boolean @default(false)
  tipoCalefaccion          String? // "Central", "Individual", "Bomba de calor"
  ventilacion              String? // "Natural", "Forzada", "Extracción"
  deteccionIncendios       Boolean @default(false)
  extincionIncendios       String? // "Rociadores", "CO2", "Manual", "Sin sistema"
  salidasEmergencia        Int? // Número de salidas de emergencia
  ascensor                 Boolean @default(false)
  numeroAscensores         Int?
  montacargas              Boolean @default(false)
  capacidadMontacargas     Float? // kg

  // Accesibilidad
  accesibleMinusvalidos Boolean @default(false)
  aseoAdaptado          Boolean @default(false)
  rampaAcceso           Boolean @default(false)

  // Servicios del edificio
  recepcion24h          Boolean @default(false)
  vigilancia            Boolean @default(false)
  controlAccesos        Boolean @default(false)
  tipoControlAcceso     String? // "Tarjeta", "Huella", "Código", "App"
  limpiezaIncluida      Boolean @default(false)
  mantenimientoIncluido Boolean @default(false)

  // Parking
  plazasParking            Int? // Plazas incluidas
  plazasParkingAdicionales Int? // Plazas disponibles adicionales
  precioParkingMensual     Float? // €/plaza/mes

  // Telecomunicaciones
  fibraOptica     Boolean  @default(false)
  operadoresFibra String[] @default([])
  cableado        String? // "Cat5e", "Cat6", "Cat6a", "Sin cableado"
  rackServidores  Boolean  @default(false)

  // Información comercial
  estado           UnitStatus @default(disponible)
  rentaMensualBase Float // Renta mensual sin CAM ni IVA
  precioM2Mensual  Float? // €/m²/mes (calculado)

  // CAM (Common Area Maintenance)
  camType    CommonAreaMaintenanceType @default(incluido_en_renta)
  camMensual Float? // Coste CAM mensual
  camIncluye String[]                  @default([]) // ["limpieza", "seguridad", "jardinería"]

  // Gastos adicionales estimados
  ibiAnual            Float? // IBI anual
  comunidadMensual    Float? // Gastos de comunidad
  seguroEdificioAnual Float? // Seguro estructura

  // Licencias y permisos
  licenciaActividad       Boolean               @default(false)
  tiposActividadPermitida CommercialUsePermit[] @default([])
  restriccionesUso        String?               @db.Text // Restricciones específicas
  certificadoEnergetico   String? // Letra de certificación
  añoCertificado         Int?

  // Marketing
  destacado        Boolean   @default(false)
  disponibleDesde  DateTime?
  imagenes         String[]  @default([])
  planos           String[]  @default([])
  tourVirtual      String?
  videoPromocional String?

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  company                Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  building               Building?               @relation("BuildingCommercialSpaces", fields: [buildingId], references: [id], onDelete: SetNull)
  commercialLeases       CommercialLease[]
  commercialInquiries    CommercialInquiry[]
  commercialDocuments    CommercialDocument[]
  commercialMaintenances CommercialMaintenance[]
  commercialVisits       CommercialVisit[]

  @@index([companyId])
  @@index([buildingId])
  @@index([tipo, estado])
  @@index([ciudad, tipo])
  @@index([rentaMensualBase])
  @@index([superficieUtil])
  @@map("commercial_spaces")
}

model CommercialLease {
  id                String @id @default(cuid())
  companyId         String
  commercialSpaceId String

  // Arrendatario (puede ser empresa o autónomo)
  arrendatarioNombre    String // Razón social o nombre
  arrendatarioCIF       String // CIF/NIF del arrendatario
  arrendatarioTipo      String  @default("empresa") // "empresa", "autonomo", "persona_fisica"
  arrendatarioActividad String? // Actividad económica/CNAE
  arrendatarioContacto  String? // Persona de contacto
  arrendatarioEmail     String
  arrendatarioTelefono  String?
  arrendatarioDireccion String? // Domicilio fiscal si diferente

  // Tipo y estado del contrato
  tipoContrato CommercialLeaseType   @default(arrendamiento_local)
  estado       CommercialLeaseStatus @default(negociacion)

  // Fechas
  fechaInicio        DateTime
  fechaFin           DateTime
  duracionAnios      Int       @default(5) // Duración pactada en años
  fechaEntregaLlaves DateTime?

  // Prórrogas
  prorrogaAutomatica    Boolean @default(true)
  duracionProrrogaAnios Int     @default(1) // Duración de cada prórroga
  prorrogasMaximas      Int? // Límite de prórrogas (null = sin límite)
  prorrogasRealizadas   Int     @default(0)
  preavisoNoRenovacion  Int     @default(6) // Meses de preaviso

  // Renta
  rentaMensualBase Float // Renta base mensual (sin IVA)
  rentaAnualBase   Float? // Renta anual (calculada)
  ivaAplicable     Float  @default(21) // % de IVA

  // Escalado de renta
  escaladoTipo       RentEscalationType @default(ipc)
  escaladoValor      Float? // Valor adicional si aplica (diferencial, %)
  fechaRevisionRenta DateTime? // Próxima fecha de revisión
  mesRevisionRenta   Int? // Mes del año para revisión (1-12)

  // Renta variable (para retail)
  rentaVariableAplica     Boolean @default(false)
  porcentajeVentas        Float? // % sobre ventas brutas
  facturacionMinimaExenta Float? // Facturación por debajo de la cual no aplica variable
  reporteVentasFrecuencia String? // "mensual", "trimestral", "anual"

  // Fianzas y garantías
  mesesFianza              Int       @default(2) // Meses de fianza legal
  importeFianza            Float // Importe de la fianza
  fianzaDepositada         Boolean   @default(false)
  fechaDepositoFianza      DateTime?
  garantiaAdicionalTipo    String? // "aval_bancario", "deposito", "seguro_caución", "ninguna"
  garantiaAdicionalMeses   Int? // Meses cubiertos por garantía adicional
  garantiaAdicionalImporte Float?

  // CAM (Common Area Maintenance)
  camIncluido  Boolean  @default(false)
  camMensual   Float? // Coste CAM si no incluido
  camConceptos String[] @default([])

  // Gastos
  gastosRepercutibles   String[] @default([]) // IBI, comunidad, seguros, etc.
  gastosNoRepercutibles String[] @default([]) // A cargo del propietario
  ibiRepercutido        Boolean  @default(true)
  comunidadRepercutida  Boolean  @default(true)
  seguroRepercutido     Boolean  @default(false)

  // Período de carencia
  carenciaAplica     Boolean @default(false)
  carenciaMeses      Int? // Meses de carencia
  carenciaTipo       String? // "total", "parcial"
  carenciaPorcentaje Float? // % de descuento si carencia parcial

  // Obra y acondicionamiento
  obraInquilinoPermitida     Boolean @default(true)
  obraRequiereAutorizacion   Boolean @default(true)
  aportacionPropietarioObra  Float? // € que aporta propietario a obra
  plazoObraMaximo            Int? // Días máximos para obras
  obligacionDevolucionEstado String? // "original", "mejorado", "negociable"

  // Subarrendamiento y cesión
  subarrendamientoPermitido Boolean @default(false)
  cesionPermitida           Boolean @default(false)
  derechoTanteoRetracto     Boolean @default(true) // Derecho de adquisición preferente

  // Uso
  usoPermitido       CommercialUsePermit[] @default([])
  usoEspecifico      String? // Descripción detallada del uso acordado
  cambioUsoPermitido Boolean               @default(false)

  // Seguros obligatorios
  seguroRCObligatorio        Boolean @default(true)
  seguroRCMinimoCobertura    Float? // € mínimos de cobertura RC
  seguroContenidoObligatorio Boolean @default(false)

  // Resolución anticipada
  penalizacionResolucionAnticipada Float? // Meses de renta como penalización
  causasResolucionSinPenalizacion  String[] @default([])

  // Documentación
  contratoFirmado Boolean   @default(false)
  fechaFirma      DateTime?
  contratoPath    String? // Path al PDF del contrato
  anexos          String[]  @default([]) // Paths a documentos anexos

  // Pagos
  diaPago        Int     @default(1) // Día del mes para pago
  metodoPago     String  @default("transferencia") // "transferencia", "domiciliacion", "cheque"
  cuentaBancaria String? // IBAN para pagos

  // Notas y observaciones
  clausulasEspeciales String? @db.Text
  notasInternas       String? @db.Text

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  commercialSpace     CommercialSpace      @relation(fields: [commercialSpaceId], references: [id], onDelete: Cascade)
  commercialPayments  CommercialPayment[]
  commercialDocuments CommercialDocument[]

  @@index([companyId])
  @@index([commercialSpaceId])
  @@index([estado])
  @@index([fechaFin])
  @@index([arrendatarioCIF])
  @@map("commercial_leases")
}

model CommercialPayment {
  id                String @id @default(cuid())
  companyId         String
  commercialLeaseId String

  // Tipo de pago
  concepto String // "Renta", "CAM", "IBI", "Renta Variable", etc.
  tipo     String @default("renta") // "renta", "cam", "ibi", "comunidad", "variable", "regularizacion", "fianza", "otro"

  // Periodo
  periodo          String // "2026-01", formato año-mes
  fechaVencimiento DateTime

  // Importes
  importeBase      Float // Importe sin IVA
  ivaAplicado      Float  @default(21)
  importeIVA       Float // IVA calculado
  importeTotal     Float // Total con IVA
  importeRetencion Float? // Retención IRPF si aplica
  importeNeto      Float? // Importe final a pagar

  // Estado
  estado         PaymentStatus @default(pendiente)
  fechaPago      DateTime?
  metodoPago     String?
  referenciaPago String? // Referencia bancaria

  // Facturación
  facturaEmitida Boolean   @default(false)
  numeroFactura  String?
  fechaFactura   DateTime?
  facturaPath    String?

  // Notas
  notas String? @db.Text

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  commercialLease CommercialLease @relation(fields: [commercialLeaseId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([commercialLeaseId])
  @@index([estado])
  @@index([periodo])
  @@index([fechaVencimiento])
  @@map("commercial_payments")
}

model CommercialInquiry {
  id                String @id @default(cuid())
  companyId         String
  commercialSpaceId String

  // Datos del interesado
  nombreEmpresa  String?
  nombreContacto String
  email          String
  telefono       String?
  cifNif         String?

  // Interés
  actividadPrevista   String?
  superficieDeseada   Float?
  presupuestoMensual  Float?
  fechaDeseadaEntrada DateTime?

  // Estado
  estado    String @default("nuevo") // "nuevo", "contactado", "visita_programada", "negociacion", "descartado", "convertido"
  prioridad String @default("media") // "baja", "media", "alta"

  // Seguimiento
  fuenteLead         String? // "web", "idealista", "fotocasa", "referido", "otro"
  notas              String?   @db.Text
  proximoSeguimiento DateTime?
  asignadoA          String? // userId del gestor asignado

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  commercialSpace CommercialSpace @relation(fields: [commercialSpaceId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([commercialSpaceId])
  @@index([estado])
  @@map("commercial_inquiries")
}

model CommercialDocument {
  id                String  @id @default(cuid())
  companyId         String
  commercialSpaceId String?
  commercialLeaseId String?

  // Documento
  nombre      String
  tipo        String // "contrato", "anexo", "licencia", "plano", "certificado", "factura", "seguro", "otro"
  descripcion String?
  path        String // URL o path del archivo
  mimeType    String?
  tamano      Int? // Bytes

