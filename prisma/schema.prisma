model DocumentoFirma {
  id            String  @id @default(cuid())
  companyId     String
  company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  titulo        String
  descripcion   String? @db.Text
  tipoDocumento String // "contrato", "adenda", "finiquito", "acta", "otro"

  // Relaciones
  contractId String?
