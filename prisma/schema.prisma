  @@index([rating])
  @@index([url])
  @@map("web_vitals")
}

// ============================================================================
// ECOSISTEMA DE INTEGRACIONES - API REST, OAuth 2.0, Webhooks
// ============================================================================

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum OAuthGrantType {
  AUTHORIZATION_CODE
  REFRESH_TOKEN
  CLIENT_CREDENTIALS
}

enum WebhookEventType {
  PROPERTY_CREATED
  PROPERTY_UPDATED
  PROPERTY_DELETED
  TENANT_CREATED
  TENANT_UPDATED
  CONTRACT_CREATED
  CONTRACT_SIGNED
  PAYMENT_CREATED
  PAYMENT_RECEIVED
  MAINTENANCE_CREATED
  MAINTENANCE_RESOLVED
  DOCUMENT_UPLOADED
  USER_CREATED
  USER_ONBOARDING_COMPLETED
}

model ApiKey {
  id String @id @default(cuid())

  // Empresa propietaria
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Key (hash SHA-256)
  key       String @unique
  keyPrefix String // Primeros 8 chars para display (sk_live_abc12345)

  // Metadata
  name        String // "Production API", "Zapier Integration", etc.
  description String? @db.Text

  // Scopes/Permissions
  scopes String[] @default(["properties:read", "tenants:read"])

  // Status
  status ApiKeyStatus @default(ACTIVE)

  // Rate limiting
  rateLimit Int @default(1000) // requests/min

  // Expiration
  expiresAt DateTime?

  // Tracking
  lastUsedAt DateTime?
  lastUsedIp String?

  // Audit
  createdBy     String
  createdByUser User      @relation(fields: [createdBy], references: [id])
  revokedBy     String?
  revokedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  logs ApiLog[]

  @@index([companyId])
  @@index([status])
  @@index([keyPrefix])
  @@map("api_keys")
}

model OAuthApp {
  id String @id @default(cuid())

  // Identificación
  clientId     String  @unique
  clientSecret String // Hasheado
  name         String
  description  String? @db.Text
  website      String?
  logo         String?

  // Tipo de app
  type String @default("PUBLIC") // PUBLIC, CONFIDENTIAL

  // OAuth settings
  redirectUris  String[] // URLs permitidas para redirect
  allowedGrants OAuthGrantType[] @default([AUTHORIZATION_CODE, REFRESH_TOKEN])
  defaultScopes String[]         @default(["properties:read"])

  // Owner (puede ser Inmova o partner externo)
  ownerId    String?
  ownerEmail String

  // Status
  active Boolean @default(true)

  // Rate limiting
  rateLimit Int @default(1000)

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  authorizationCodes OAuthAuthorizationCode[]
  accessTokens       OAuthAccessToken[]

  @@index([clientId])
  @@index([ownerId])
  @@map("oauth_apps")
}

model OAuthAuthorizationCode {
  id String @id @default(cuid())

  // App que solicitó el código
  appId String
  app   OAuthApp @relation(fields: [appId], references: [id], onDelete: Cascade)

  // Usuario que autorizó
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Código
  code String @unique

  // Scopes autorizados
  scopes String[]

  // Redirect URI
  redirectUri String

  // PKCE (opcional)
  codeChallenge       String?
  codeChallengeMethod String? // S256 o plain

  // Status
  used   Boolean   @default(false)
  usedAt DateTime?

  // Expiration (códigos duran 10 minutos)
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([code])
  @@index([appId])
  @@index([userId])
  @@map("oauth_authorization_codes")
}

model OAuthAccessToken {
  id String @id @default(cuid())

  // App que tiene el token
  appId String
  app   OAuthApp @relation(fields: [appId], references: [id], onDelete: Cascade)

  // Usuario asociado
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Token
  token String @unique

  // Scopes
  scopes String[]

  // Expiration (tokens duran 1 hora)
  expiresAt DateTime

  // Refresh token
  refreshToken     String?   @unique
  refreshExpiresAt DateTime?

  // Status
  revoked   Boolean   @default(false)
  revokedAt DateTime?

  // Tracking
  lastUsedAt DateTime?
  lastUsedIp String?

  createdAt DateTime @default(now())

  // Relations
  logs ApiLog[]

  @@index([token])
  @@index([refreshToken])
  @@index([appId])
  @@index([userId])
  @@map("oauth_access_tokens")
}

model WebhookSubscription {
  id String @id @default(cuid())

  // Empresa suscrita
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // URL de destino
  url String

  // Eventos suscritos
  events WebhookEventType[]

  // Secret para firma HMAC
  secret String

  // Status
  active Boolean @default(true)

  // Retry config
  maxRetries Int @default(3)

  // Stats
  successCount  Int       @default(0)
  failureCount  Int       @default(0)
  lastSuccessAt DateTime?
  lastFailureAt DateTime?

  // Audit
  createdBy     String
  createdByUser User   @relation(fields: [createdBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  deliveries WebhookDelivery[]

  @@index([companyId])
  @@index([active])
  @@map("webhook_subscriptions")
}

model WebhookDelivery {
  id String @id @default(cuid())

  // Suscripción
  subscriptionId String
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  // Evento
  event   WebhookEventType
  payload Json

  // Request
  url     String
  method  String @default("POST")
  headers Json?

  // Response
  statusCode   Int?
  responseBody String? @db.Text
  responseTime Int? // ms

  // Status
  success     Boolean   @default(false)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  nextRetryAt DateTime?

  // Error
  error String? @db.Text

  // Audit
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([subscriptionId])
  @@index([event])
  @@index([success])
  @@map("webhook_deliveries")
}

model ApiLog {
  id String @id @default(cuid())

  // Company/API Key
  companyId    String?
  company      Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  apiKeyId     String?
  apiKey       ApiKey?           @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  oauthTokenId String?
  oauthToken   OAuthAccessToken? @relation(fields: [oauthTokenId], references: [id], onDelete: SetNull)

  // Request
  method  String // GET, POST, PUT, DELETE
  path    String // /api/v1/properties
  query   Json?
  body    Json?
  headers Json?

  // Response
  statusCode   Int
  responseBody Json?
  responseTime Int // ms

  // Metadata
  ipAddress String
  userAgent String?

  // Rate limiting
  rateLimitHit Boolean @default(false)

  // Error
  error String? @db.Text

  timestamp DateTime @default(now())

  @@index([companyId])
  @@index([apiKeyId])
  @@index([oauthTokenId])
  @@index([method])
  @@index([path])
  @@index([statusCode])
  @@index([timestamp])
  @@map("api_logs")
}

model IntegrationTemplate {
  id String @id @default(cuid())

  // Identificación
  name        String
  slug        String  @unique
  description String  @db.Text
  icon        String?
  logo        String?

  // Categoría
  category String // automation, analytics, communication, etc.

  // Provider
  provider String // zapier, make, google, slack, etc.

  // Template config
  config Json // Configuración pre-definida
  steps  Json // Pasos del wizard

  // Features
  triggers String[]
  actions  String[]

  // Popularidad
  installCount Int    @default(0)
  rating       Float?

  // Status
  active   Boolean @default(true)
  featured Boolean @default(false)

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([category])
  @@index([provider])
  @@map("integration_templates")
}

model UserOnboardingProgress {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Progress
  completedSteps String[] // IDs de pasos completados
  currentStep    Int      @default(0)
  isCompleted    Boolean  @default(false)
  setupVersion   String? // Versión del setup para tracking

  // Timestamps
  lastUpdated DateTime @default(now()) @updatedAt
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([isCompleted])
  @@map("user_onboarding_progress")
}

// ============================================================================
// SISTEMA DE ONBOARDING DOCUMENTAL CON IA
// Importación inteligente de documentos para auto-parametrización
// ============================================================================

enum DocumentImportStatus {
  pending // En cola de procesamiento
  processing // Siendo procesado
  analyzing // Análisis de IA en progreso
  awaiting_review // Pendiente de revisión manual
  approved // Aprobado y aplicado
  rejected // Rechazado por el usuario
  failed // Error en procesamiento
  partial // Parcialmente procesado
}

enum DocumentImportCategory {
  escritura_propiedad // Escrituras de compraventa
  contrato_alquiler // Contratos de arrendamiento
  dni_nie // Documentos de identidad
  factura // Facturas de proveedores
  seguro // Pólizas de seguros
  certificado_energetico // Certificados energéticos
  acta_comunidad // Actas de comunidades
  recibo_pago // Recibos y comprobantes
  nota_simple // Notas simples del registro
  ite_iee // Inspección técnica de edificios
  licencia // Licencias y permisos
  fianza // Justificantes de fianza
  inventario // Inventarios de inmuebles
  foto_inmueble // Fotografías de propiedades
  plano // Planos y croquis
  otro // Otros documentos
}

enum ExtractedDataType {
  company_info // Datos de la empresa (CIF, nombre, dirección)
  property_info // Datos de propiedad (dirección, superficie, referencia catastral)
  tenant_info // Datos de inquilino (nombre, DNI, contacto)
  contract_info // Datos de contrato (fechas, importes, condiciones)
  financial_info // Datos financieros (importes, fechas de pago)
  insurance_info // Datos de seguros (póliza, coberturas, vencimiento)
  energy_info // Datos energéticos (calificación, consumos)
  community_info // Datos de comunidad (cuotas, acuerdos)
  provider_info // Datos de proveedores (nombre, CIF, servicios)
  maintenance_info // Datos de mantenimiento (fechas ITE, revisiones)
}

model DocumentImportBatch {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Información del batch
  name        String?
  description String?

  // Estadísticas
  totalFiles      Int @default(0)
  processedFiles  Int @default(0)
  successfulFiles Int @default(0)
  failedFiles     Int @default(0)
  pendingReview   Int @default(0)

  // Estado general
  status   DocumentImportStatus @default(pending)
  progress Float                @default(0) // 0-100

  // Configuración
  autoApprove         Boolean @default(false) // Auto-aprobar datos con alta confianza
  confidenceThreshold Float   @default(0.8) // Umbral de confianza (0-1)

  // Resultados
  extractedEntities Json? // Resumen de entidades extraídas
  appliedChanges    Json? // Cambios aplicados al sistema
  errors            Json? // Errores encontrados

  // Timestamps
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  documents DocumentImport[]

  @@index([companyId])
  @@index([userId])
  @@index([status])
  @@map("document_import_batches")
}

model DocumentImport {
  id        String              @id @default(cuid())
  batchId   String
  batch     DocumentImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  companyId String
  company   Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Archivo original
  originalFilename String
  mimeType         String
  fileSize         Int
  s3Key            String
  checksum         String? // SHA256 para detectar duplicados

  // Clasificación (detectada por IA)
  detectedCategory   DocumentImportCategory?
  categoryConfidence Float? // Confianza en la clasificación

  // Estado del procesamiento
  status          DocumentImportStatus @default(pending)
  processingStage String? // Etapa actual: "uploading", "ocr", "ai_analysis", "validation", "review"

  // OCR y extracción de texto
  ocrText       String? @db.Text
  ocrConfidence Float?
  ocrLanguage   String?
  pageCount     Int?

  // Validación de propiedad
  ownershipValidated Boolean  @default(false)
  detectedCIF        String? // CIF detectado en el documento
  matchesCompanyCIF  Boolean? // Si coincide con el CIF de la empresa
  ownershipNotes     String? // Notas sobre la validación

  // Errores
  errorMessage String?
  errorDetails Json?

  // Timestamps
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  analyses      AIDocumentAnalysis[]
  extractedData ExtractedDocumentData[]

  @@index([batchId])
  @@index([companyId])
  @@index([status])
  @@index([detectedCategory])
  @@map("document_imports")
}

model AIDocumentAnalysis {
  id         String         @id @default(cuid())
  documentId String
  document   DocumentImport @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Modelo y versión de IA usado
  aiModel       String  @default("claude-3-5-sonnet-20241022")
  aiVersion     String?
  promptVersion String? // Para tracking de mejoras en prompts

  // Resultados del análisis
  summary       String? @db.Text // Resumen del documento
  documentType  String? // Tipo específico detectado
  keyEntities   Json? // Entidades clave extraídas
  relationships Json? // Relaciones entre entidades

  // Confianza global
  overallConfidence Float?

  // Flags de alerta
  hasWarnings        Boolean  @default(false)
  warnings           Json? // Lista de advertencias
  hasSensitiveData   Boolean  @default(false)
  sensitiveDataTypes String[] // Tipos de datos sensibles detectados

  // Sugerencias de parametrización
  suggestedActions Json? // Acciones sugeridas (crear propiedad, actualizar inquilino, etc.)

  // Métricas de procesamiento
  processingTimeMs Int?
  tokensUsed       Int?
  estimatedCost    Float? // Coste estimado de la llamada a la IA

  // Timestamps
  createdAt DateTime @default(now())

  @@index([documentId])
  @@map("ai_document_analyses")
}

model ExtractedDocumentData {
  id         String         @id @default(cuid())
  documentId String
  document   DocumentImport @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Tipo de dato extraído
  dataType ExtractedDataType

  // Campo específico extraído
  fieldName  String // Ej: "tenant_name", "monthly_rent", "property_address"
  fieldValue String @db.Text // Valor extraído

  // Confianza y validación
  confidence  Float // 0-1
  isValidated Boolean   @default(false)
  validatedBy String? // userId que validó
  validatedAt DateTime?

  // Corrección manual
  originalValue String? @db.Text // Valor original si fue corregido
  wasCorrected  Boolean @default(false)

  // Mapeo a entidad del sistema
  targetEntity   String? // Ej: "Property", "Tenant", "Contract"
  targetEntityId String? // ID de la entidad si ya existe
  targetField    String? // Campo de la entidad destino

  // Estado de aplicación
  wasApplied Boolean   @default(false)
  appliedAt  DateTime?

  // Ubicación en documento
  pageNumber  Int?
  boundingBox Json? // Coordenadas en el documento

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([documentId])
  @@index([dataType])
  @@index([fieldName])
  @@index([wasApplied])
  @@map("extracted_document_data")
}

model OnboardingDocumentSession {
  id        String  @id @default(cuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Estado del onboarding documental
  isActive     Boolean @default(true)
  currentPhase String  @default("upload") // "upload", "processing", "review", "applying", "complete"

  // Resumen de lo importado
  totalDocuments  Int @default(0)
  propertiesFound Int @default(0)
  tenantsFound    Int @default(0)
  contractsFound  Int @default(0)

  // Entidades creadas/actualizadas
  entitiesCreated Json? // { properties: [], tenants: [], contracts: [] }
  entitiesUpdated Json?

  // Datos pendientes de revisión
  pendingReviewData Json? // Datos que necesitan confirmación manual

  // Configuración del usuario
  preferences Json? // Preferencias de parametrización

  // Timestamps
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  lastActivityAt DateTime  @default(now())

  @@index([companyId])
  @@index([userId])
  @@index([isActive])
  @@map("onboarding_document_sessions")
}

// ==========================================
// SOCIEDADES INVERSORAS / PATRIMONIALES
// Modelos para tracking de activos, hipotecas,
// amortizaciones y fiscalidad de SLs
// ==========================================

enum AssetType {
  vivienda
  local_comercial
  oficina
  garaje
  trastero
  nave_industrial
  solar
  otro
}

enum MortgageType {
  fijo
  variable
  mixto
}

enum MortgageStatus {
  activa
  amortizada
  cancelada
  novada
}

enum DepositStatus {
  pendiente_deposito
  depositada
  devuelta
  retenida_parcial
  retenida_total
}

/// Datos de adquisicion de un inmueble (Building o Unit)
/// Tracking del valor de compra, gastos, y valor actual
model AssetAcquisition {
  id         String  @id @default(cuid())
  companyId  String
  buildingId String?
  unitId     String?

  // Datos de compra
  assetType         AssetType
  fechaAdquisicion  DateTime
  precioCompra      Float // Precio escriturado
  gastosNotaria     Float     @default(0)
  gastosRegistro    Float     @default(0)
  gastosGestoria    Float     @default(0)
  impuestoCompra    Float     @default(0) // ITP o IVA+AJD
  otrosGastosCompra Float     @default(0)

  // Desglose catastral (necesario para amortizacion)
  valorCatastralTotal        Float?
  valorCatastralSuelo        Float?
  valorCatastralConstruccion Float?
  referenciaCatastral        String?

  // Valor actual
  valorMercadoEstimado Float? // Ultima valoracion de mercado
  fechaValoracion      DateTime? // Fecha de ultima valoracion

  // Reformas capitalizables (incrementan valor del activo)
  reformasCapitalizadas Float @default(0)

  // Datos calculados (se recalculan)
  inversionTotal        Float? // precioCompra + gastos + reformas
  amortizacionAcumulada Float  @default(0)
  valorContableNeto     Float? // inversionTotal - amortizacionAcumulada
  plusvaliaLatente      Float? // valorMercado - valorContable

  notas     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  building Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  unit     Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)

  mortgages     Mortgage[]
  depreciations DepreciationEntry[]

  @@index([companyId])
  @@index([buildingId])
  @@index([unitId])
}

/// Hipoteca asociada a un activo inmobiliario
model Mortgage {
  id        String @id @default(cuid())
  assetId   String
  companyId String

  // Datos del prestamo
  entidadFinanciera String
  numeroExpediente  String?
  tipoHipoteca      MortgageType
  estado            MortgageStatus @default(activa)

  capitalInicial   Float // Importe original del prestamo
  capitalPendiente Float // Capital vivo actual
  tipoInteres      Float // Tipo de interes actual (%)
  diferencial      Float? // Diferencial sobre Euribor (para variable/mixto)
  indiceReferencia String? // "euribor_12m", "euribor_6m", etc.
  plazoAnos        Int // Plazo total en anos
  cuotaMensual     Float // Cuota mensual actual
  diaVencimiento   Int     @default(1) // Dia del mes de pago

  fechaConstitucion DateTime // Fecha firma hipoteca
  fechaVencimiento  DateTime // Fecha fin del prestamo
  fechaRevision     DateTime? // Proxima revision de tipo (variable/mixto)
  periodoCarencia   Int? // Meses de carencia (si aplica)

  // Gastos asociados
  gastosConstitucion  Float  @default(0) // Notaria, tasacion, etc.
  comisionApertura    Float  @default(0)
  comisionCancelacion Float? // Comision por cancelacion anticipada

  // Seguros vinculados
  seguroVidaAnual  Float?
  seguroHogarAnual Float?

  notas     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  asset             AssetAcquisition  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  amortizationTable MortgagePayment[]

  @@index([companyId])
  @@index([assetId])
}

/// Pago mensual de hipoteca (tabla de amortizacion real)
model MortgagePayment {
  id         String @id @default(cuid())
  mortgageId String

  fecha            DateTime
  cuotaTotal       Float
  capital          Float // Parte de capital amortizado
  intereses        Float // Parte de intereses (gasto deducible)
  capitalPendiente Float // Capital restante tras este pago
  pagado           Boolean  @default(false)

  createdAt DateTime @default(now())

  mortgage Mortgage @relation(fields: [mortgageId], references: [id], onDelete: Cascade)

  @@index([mortgageId])
  @@index([fecha])
}

/// Amortizacion contable anual de un activo (3% construccion para IS)
model DepreciationEntry {
  id      String @id @default(cuid())
  assetId String

  ano                   Int
  baseAmortizable       Float // Valor construccion + reformas capitalizables
  porcentaje            Float // Tipicamente 3% para inmuebles
  cuotaAnual            Float // baseAmortizable * porcentaje / 100
  amortizacionAcumulada Float // Suma de todas las cuotas hasta este ano

  createdAt DateTime @default(now())

  asset AssetAcquisition @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, ano])
  @@index([assetId])
}

/// Tracking de fianzas depositadas en organismo autonomico
model FianzaDeposit {
  id         String @id @default(cuid())
  contractId String
  companyId  String

  importeFianza     Float
  mesesFianza       Int           @default(1)
  organismoDeposito String? // IVIMA, INCASOL, AVVR, etc.
  numeroDeposito    String? // Referencia del deposito
  fechaDeposito     DateTime?
  fechaDevolucion   DateTime?
  importeDevuelto   Float?
  importeRetenido   Float?
  motivoRetencion   String?       @db.Text
  estado            DepositStatus @default(pendiente_deposito)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([companyId])
  @@index([estado])
}

// ==========================================
// ANALISIS DE INVERSIONES (VIDARO HOLDING)
// Rent roll, OPEX, CAPEX, financiacion,
// tabla de sensibilidad sobre precio maximo
// ==========================================

enum AnalysisUnitType {
  vivienda
  garaje
  local
  trastero
  oficina
  otro
}

/// Analisis de inversion inmobiliaria completo
model InvestmentAnalysis {
  id        String @id @default(cuid())
  companyId String
  createdBy String

  // Datos del activo
  nombre      String // Nombre descriptivo del analisis
  direccion   String?
  ciudad      String?
  tipoActivo  String? // edificio_completo, unidad_individual, cartera
  askingPrice Float // Precio que piden (techo de la tabla sensibilidad)

  // Datos de compra
  gastosNotaria     Float @default(0)
  gastosRegistro    Float @default(0)
  impuestoCompra    Float @default(0) // ITP o IVA+AJD
  comisionCompra    Float @default(0) // Comision agencia compra (%)
  otrosGastosCompra Float @default(0)

  // CAPEX (reformas/mejoras)
  capexReforma     Float @default(0)
  capexImprevistos Float @default(0) // % sobre capex
  capexOtros       Float @default(0)

  // OPEX anual (gastos recurrentes)
  ibiAnual            Float @default(0)
  comunidadMensual    Float @default(0)
  seguroAnual         Float @default(0)
  mantenimientoAnual  Float @default(0) // % sobre renta o fijo
  gestionAdminPct     Float @default(0) // % sobre renta bruta
  vacioEstimadoPct    Float @default(5) // % del ano vacio
  comisionAlquilerPct Float @default(0) // Comision por nueva contratacion
  otrosGastosAnuales  Float @default(0)

  // Financiacion
  usaFinanciacion  Boolean @default(false)
  ltv              Float? // % financiado sobre precio compra
  tipoInteres      Float? // % anual
  plazoAnos        Int?
  comisionApertura Float? // %

  // Potencial de zona (EUR/m2)
  precioM2Zona       Float? // EUR/m2 medio de alquiler en la zona
  precioM2ZonaFuente String? // "manual", "ia", "idealista", etc.

  // Rent roll (JSON array de unidades)
  // Cada entrada: { tipo, referencia, superficie, rentaMensual, estado }
  rentRoll Json @default("[]")

  // Resultados calculados (se regeneran al guardar)
  rentaPotencialAnual       Float? // Si todas las unidades estuvieran al precio/m2 de zona
  yieldPotencial            Float? // Yield si se alquila a precio de mercado
  gapRentaActualVsPotencial Float? // % de diferencia renta actual vs potencial
  rentaBrutaAnual           Float?
  rentaNetaAnual            Float?
  inversionTotal            Float?
  capitalPropio             Float?
  importeHipoteca           Float?
  cuotaHipotecaMensual      Float?
  cashFlowAnual             Float?
  yieldBruto                Float?
  yieldNeto                 Float?
  cashOnCash                Float?
  paybackAnos               Float?
  // Tabla de sensibilidad (JSON)
  // Array de { precio, yield, cashOnCash, cashFlow }
  tablaSensibilidad         Json?

  notas     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([createdBy])
}

// ============================================
// GOCARDLESS - PAGOS SEPA DIRECT DEBIT
// ============================================

enum SepaMandateStatus {
  pending_customer_approval
  pending_submission
  submitted
  active
  suspended_by_payer
  failed
  cancelled
  expired
}

enum SepaPaymentStatus {
  pending_customer_approval
  pending_submission
  submitted
  confirmed
  paid_out
  cancelled
  customer_approval_denied
  failed
  charged_back
}

enum SepaSubscriptionStatus {
  pending_customer_approval
  customer_approval_denied
  active
  finished
  cancelled
  paused
}

model GCCustomer {
  id        String @id @default(cuid())
  companyId String

  // GoCardless IDs
  gcCustomerId    String  @unique // ID en GoCardless (CU...)
  gcBankAccountId String? // ID de cuenta bancaria (BA...)

  // Relacion con inquilino
  tenantId String? @unique
  tenant   Tenant? @relation("TenantGCCustomer", fields: [tenantId], references: [id], onDelete: SetNull)

  // Datos del cliente
  email       String
  givenName   String
  familyName  String
  companyName String?
  countryCode String  @default("ES")
  iban        String? // Ultimos 4 digitos
  bankName    String?

  // Estado
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  company  Company       @relation("CompanyGCCustomers", fields: [companyId], references: [id], onDelete: Cascade)
  mandates SepaMandate[]
  metadata Json?

  @@unique([companyId, tenantId])
  @@index([companyId])
  @@index([tenantId])
  @@index([gcCustomerId])
  @@map("gc_customers")
}

model SepaMandate {
  id        String @id @default(cuid())
  companyId String

  // GoCardless IDs
  gcMandateId  String @unique // ID en GoCardless (MD...)
  gcCustomerId String

  // Relacion
  customerId String
  customer   GCCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Datos del mandato
  reference              String? // Referencia unica SEPA
  scheme                 String            @default("sepa_core") // sepa_core, bacs, etc
  status                 SepaMandateStatus @default(pending_submission)
  nextPossibleChargeDate String? // YYYY-MM-DD

  // Metadatos
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  company       Company            @relation("CompanySepaMandates", fields: [companyId], references: [id], onDelete: Cascade)
  payments      SepaPayment[]
  subscriptions SepaSubscription[]

  @@index([companyId])
  @@index([gcCustomerId])
  @@index([status])
  @@map("sepa_mandates")
}

model SepaPayment {
  id        String @id @default(cuid())
  companyId String

  // GoCardless IDs
  gcPaymentId String @unique // ID en GoCardless (PM...)

  // Relaciones GoCardless
  mandateId String
  mandate   SepaMandate @relation(fields: [mandateId], references: [id], onDelete: Cascade)

  subscriptionId String?
  subscription   SepaSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  // Datos del pago
  amount      Int // En centimos (1200 = 12.00 EUR)
  currency    String            @default("EUR")
  description String
  reference   String? // Referencia para conciliacion
  chargeDate  String? // YYYY-MM-DD
  status      SepaPaymentStatus @default(pending_submission)

  // Conciliacion con Payment de Inmova
  inmovaPaymentId String? // FK a Payment (pago de alquiler)
  inmovaPayment   Payment? @relation("SepaToInmovaPayment", fields: [inmovaPaymentId], references: [id], onDelete: SetNull)

  // Conciliacion con contrato/inquilino
  tenantId   String?
  contractId String?

  // Payout (cuando GC transfiere a tu cuenta)
  gcPayoutId   String? // ID del payout (PO...)
  payoutDate   DateTime?
  payoutAmount Int? // Monto neto recibido (despues de fees)

  // Fees
  gcFeeAmount Int? // Fee de GoCardless en centimos

  // Estado de conciliacion
  conciliado       Boolean   @default(false)
  conciliadoEn     DateTime?
  conciliadoPor    String?
  notaConciliacion String?   @db.Text

  // Errores y reintentos
  failureReason  String?
  chargeBackDate DateTime?
  amountRefunded Int       @default(0)

  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  company Company @relation("CompanySepaPayments", fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([mandateId])
  @@index([status])
  @@index([chargeDate])
  @@index([conciliado])
  @@index([gcPayoutId])
  @@index([tenantId])
  @@index([contractId])
  @@map("sepa_payments")
}

model SepaSubscription {
  id        String @id @default(cuid())
  companyId String

  // GoCardless IDs
  gcSubscriptionId String @unique // ID en GoCardless (SB...)

  // Relacion
  mandateId String
  mandate   SepaMandate @relation(fields: [mandateId], references: [id], onDelete: Cascade)

  // Datos de la suscripcion
  name         String
  amount       Int // En centimos
  currency     String                 @default("EUR")
  interval     Int                    @default(1)
  intervalUnit String                 @default("monthly") // weekly, monthly, yearly
  dayOfMonth   Int? // 1-28
  startDate    String? // YYYY-MM-DD
  endDate      String? // YYYY-MM-DD
  status       SepaSubscriptionStatus @default(active)

  // Relaciones Inmova
  tenantId   String?
  contractId String?

  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  company  Company       @relation("CompanySepaSubscriptions", fields: [companyId], references: [id], onDelete: Cascade)
  payments SepaPayment[]

  @@index([companyId])
  @@index([mandateId])
  @@index([status])
  @@index([tenantId])
  @@index([contractId])
  @@map("sepa_subscriptions")
}

model GCPayout {
  id        String @id @default(cuid())
  companyId String

  // GoCardless IDs
  gcPayoutId String @unique // ID en GoCardless (PO...)

  // Datos del payout
  amount      Int // En centimos
  currency    String   @default("EUR")
  arrivalDate DateTime // Fecha de llegada a cuenta bancaria
  status      String // pending, paid, bounced
  reference   String?

  // Desglose
  debitCount   Int @default(0)
  debitAmount  Int @default(0)
  feeAmount    Int @default(0)
  refundAmount Int @default(0)

  // Conciliacion bancaria
  conciliado        Boolean   @default(false)
  conciliadoEn      DateTime?
  bankTransactionId String? // FK a BankTransaction si se concilia
  notaConciliacion  String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation("CompanyGCPayouts", fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([arrivalDate])
  @@index([conciliado])
  @@map("gc_payouts")
}

model GCWebhookEvent {
  id        String  @id @default(cuid())
  companyId String?

  // Datos del evento
  gcEventId    String @unique // ID del evento en GC
  resourceType String // payments, mandates, subscriptions, payouts, refunds
  action       String // created, confirmed, paid_out, failed, etc.
  resourceId   String // ID del recurso afectado

  // Procesamiento
  processed   Boolean   @default(false)
  processedAt DateTime?
  error       String?   @db.Text

  // Payload completo
  payload Json

  createdAt DateTime @default(now())

  @@index([gcEventId])
  @@index([resourceType, action])
  @@index([processed])
  @@map("gc_webhook_events")
}

// ═══════════════════════════════════════════════════════════════
// FAMILY OFFICE ADD-ON — Gestión Patrimonial Integral
// Consolida: inmobiliario + carteras financieras + PE + tesorería
// ═══════════════════════════════════════════════════════════════

enum FinancialEntityType {
  banca_privada
  gestora_fondos
  custodio
  banca_comercial
  broker
  aseguradora
  otro_financiero
}

enum FinancialInstrumentType {
  fondo_inversion
  sicav
  accion
  bono
  etf
  deposito
  cuenta_corriente
  plan_pensiones
  seguro_vida
  pe_fund
  real_estate_fund
  derivado
  divisa
  cripto
  otro_instrumento
}

enum FinancialTxType {
  compra
  venta
  dividendo
  cupon
  comision
  transferencia_entrada
  transferencia_salida
  aportacion
  reembolso
  interes
  capital_call
  distribucion
  otro_movimiento
}

enum ParticipationType {
  filial_100
  participada_mayoritaria
  participada_minoritaria
  pe_fund
  coinversion
  joint_venture
}

model FinancialAccount {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Entidad
  entidad      String // Banca March, Pictet, UBS, CACEIS, Inversis, etc.
  tipoEntidad  FinancialEntityType
  numeroCuenta String? // IBAN o número de cuenta
  alias        String? // "Cartera Pictet", "Cuenta Bankinter"

  // Divisa y saldos
  divisa       String @default("EUR")
  saldoActual  Float  @default(0)
  valorMercado Float  @default(0) // Valor total de posiciones
  pnlTotal     Float  @default(0) // P&L acumulado

  // Conexión
  conexionTipo String    @default("manual") // api_psd2, swift, ocr_pdf, manual
  ultimaSync   DateTime?
  apiConfig    Json? // Configuración de conexión (encrypted)

  // Estado
  activa Boolean @default(true)
  notas  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  positions    FinancialPosition[]
  transactions FinancialTransaction[]

  @@index([companyId])
  @@index([entidad])
  @@map("financial_accounts")
}

model FinancialPosition {
  id        String           @id @default(cuid())
  accountId String
  account   FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // Instrumento
  nombre    String // "Pictet Global Bonds", "Iberdrola", etc.
  isin      String? // ES0144580Y14, LU0128467544
  ticker    String? // IBE.MC, AAPL
  tipo      FinancialInstrumentType
  categoria String? // "Renta Fija EUR", "RV Global", "Monetario"

  // Posición
  cantidad    Float  @default(0) // Participaciones o títulos
  precioMedio Float  @default(0) // Coste medio de adquisición
  valorActual Float  @default(0) // Valor de mercado actual
  divisa      String @default("EUR")

  // P&L
  costeTotal     Float @default(0) // cantidad * precioMedio
  pnlNoRealizado Float @default(0) // valorActual - costeTotal
  pnlRealizado   Float @default(0) // Ganancias ya materializadas
  pnlPct         Float @default(0) // % rentabilidad

  // Metadata
  fechaCompra         DateTime?
  ultimaActualizacion DateTime?
  peso                Float? // % del total de la cuenta

  // Rentabilidades (G11: return12m, returnYtd por posición)
  return12m Float? // Rentabilidad últimos 12 meses (%)
  returnYtd Float? // Rentabilidad YTD (%)

  // Detalle bonos (G10: TIR, duración, cupón, vencimiento, rating)
  maturityDate DateTime? // Fecha vencimiento
  couponRate   Float? // Cupón (%)
  yieldAtCost  Float? // TIR de compra
  currentYield Float? // TIR actual
  duration     Float? // Duración modificada
  rating       String? // Rating crediticio (Baa1, A3, etc.)
  nominal      Float? // Valor nominal

  // Portfolio/custodian tracking (G5: multi-portfolio)
  portfolioCode String? // "1149.01", "1149.03", "1142.09"
  custodian     String? // "Inversis", "Pictet", "Banca March", "CACEIS"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions FinancialTransaction[]

  @@index([accountId])
  @@index([isin])
  @@index([tipo])
  @@index([portfolioCode])
  @@map("financial_positions")
}

model FinancialTransaction {
  id         String             @id @default(cuid())
  accountId  String
  account    FinancialAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  positionId String?
  position   FinancialPosition? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  // Movimiento
  tipo     FinancialTxType
  fecha    DateTime
  concepto String
  importe  Float // Positivo = entrada, Negativo = salida
  divisa   String          @default("EUR")

  // Detalle para compra/venta
  cantidad Float? // Participaciones/títulos
  precio   Float? // Precio por unidad
  comision Float? // Comisión cobrada

  // Referencia
  referencia String? // Número de operación del banco
  notas      String? @db.Text

  createdAt DateTime @default(now())

  @@index([accountId])
  @@index([fecha])
  @@index([tipo])
  @@map("financial_transactions")
}

// ═══════════════════════════════════════════════════════════════
// SISTEMA DE SUGERENCIAS INTELIGENTES DE GESTIÓN
// ═══════════════════════════════════════════════════════════════

enum SuggestionArea {
  inmobiliario
  financiero
  operacional
  fiscal
}

enum SmartSuggestionStatus {
  pendiente
  vista
  aceptada
  descartada
  completada
}

model SmartSuggestion {
  id        String @id @default(cuid())
  companyId String

  // Clasificación
  area      SuggestionArea
  prioridad SuggestionPriority    @default(media)
  estado    SmartSuggestionStatus @default(pendiente)
  codigo    String // "CONTRACT_EXPIRING", "UNIT_VACANT_30D", "PE_TVPI_LOW", etc.

  // Contenido
  titulo      String
  descripcion String  @db.Text
  accion      String? // "Renovar contrato", "Ajustar precio", etc.
  enlace      String? // Deep link a la página relevante

  // Contexto
  entityType String? // "contract", "unit", "participation", "account"
  entityId   String? // ID del objeto relacionado
  metadata   Json? // Datos adicionales (importes, fechas, etc.)

  // Destinatario
  targetRole   String? // "administrador", "gestor", "super_admin"
  targetUserId String? // Usuario específico (null = todos los del rol)

  // Notificación
  notificadoInApp   Boolean   @default(false)
  notificadoEmail   Boolean   @default(false)
  fechaNotificacion DateTime?

  // Auditoría
  resueltoPor     String?
  fechaResolucion DateTime?
  notasResolucion String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, estado])
  @@index([companyId, area])
  @@index([prioridad, estado])
  @@index([createdAt])
  @@map("smart_suggestions")
}

model Participation {
  id        String  @id @default(cuid())
  companyId String // Holding (ej: Vidaro)
  company   Company @relation("HoldingParticipations", fields: [companyId], references: [id], onDelete: Cascade)

  // Sociedad participada
  targetCompanyName String // "Disfasa S.L.", "Facundo S.L."
  targetCompanyCIF  String?
  targetCompanyId   String? // ID en INMOVA si es filial registrada

  // Participación
  tipo             ParticipationType
  porcentaje       Float // 100, 51, 33.33, etc.
  fechaAdquisicion DateTime
  costeAdquisicion Float             @default(0) // Precio pagado

  // Valoración
  valorContable   Float     @default(0) // Valor en libros
  valorEstimado   Float? // Última valoración estimada
  fechaValoracion DateTime?

  // PE specifics - Capital Management
  compromisoTotal    Float? // Total committed
  capitalLlamado     Float? // Total called/desembolsado
  capitalPendiente   Float? // Desembolsos pendientes (compromisoTotal - capitalLlamado)
  capitalDistribuido Float? // Total distributed (distribuciones acumuladas)

  // PE specifics - Valoración y Métricas
  valoracionActual Float? // NAV actual del fondo
  tvpi             Float? // Total Value to Paid-In = (Valoración + Distribuciones) / Desembolsos
  dpi              Float? // Distributed to Paid-In = Distribuciones / Desembolsos
  moic             Float? // Multiple on Invested Capital
  irr              Float? // Internal Rate of Return (%)

  // PE specifics - Metadata
  anoCompromiso         Int? // Año vintage (2019, 2020, 2023...)
  vehiculoInversor      String? // "VIBLA_SCR" | "VIDARO_DIRECTO"
  gestora               String? // "MdF Gestefin" etc.
  fechaUltimaValoracion DateTime? // Fecha del último NAV

  // PE specifics - Rentabilidad periodo
  patrimonioInicioPeriodo Float? // NAV al inicio del periodo actual
  rentabilidadPeriodoEur  Float? // Rentabilidad € del periodo
  rentabilidadPeriodoPct  Float? // Rentabilidad % del periodo
  desembolsosPeriodo      Float? // Desembolsos realizados en el periodo
  reembolsosPeriodo       Float? // Reembolsos recibidos en el periodo

  // Estado
  activa Boolean @default(true)
  notas  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([tipo])
  @@index([vehiculoInversor])
  @@map("participations")
}

// G1: Histórico mensual real — snapshots de cada reporting PDF importado
model MonthlySnapshot {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation("CompanyMonthlySnapshots", fields: [companyId], references: [id], onDelete: Cascade)

  portfolioCode String // "1149.01" (AF), "1149.02" (PE), "1149.03" (AR), "1142.09" (AMPER)
  portfolioName String // "BALDOMERO AF GRUPO"
  reportDate    DateTime // Último día del mes del reporting
  reportType    String // "AF", "AR", "AMPER", "MIFID"

  // Resumen patrimonial
  totalValue    Float // Patrimonio total a cierre de mes
  previousValue Float // Patrimonio mes anterior
  deposits      Float @default(0) // Aportaciones/retiradas
  netPnl        Float @default(0) // Beneficio neto
  fees          Float @default(0) // Comisiones totales (G7)

  // Asset allocation (G4: con targets)
  monetario     Float @default(0) // Valor en mercado monetario
  rentaFija     Float @default(0)
  rentaVariable Float @default(0)
  commodities   Float @default(0)
  alternativos  Float @default(0)

  // Targets (asset allocation objetivo — G4)
  targetMonetario     Float? // % objetivo mercado monetario
  targetRentaFija     Float? // % objetivo renta fija
  targetRentaVariable Float? // % objetivo renta variable

  // Performance (G2)
  returnYtd            Float? // Rentabilidad YTD (%)
  returnSinceInception Float? // Desde inicio (%)
  annualizedReturn     Float? // Anualizada (%)
  return2023           Float?
  return2024           Float?
  return2025           Float?

  // Riesgo (G9)
  volatility12m Float? // Volatilidad 12 meses (%)
  sharpeRatio   Float? // Ratio de Sharpe

  // Desglose por custodio (G3) — JSON array: [{custodian, total, pnl, deposits, previousValue}]
  custodianBreakdown Json?

  // Comisiones desglosadas (G7) — JSON: {gestionMdF, consultoria, depositaria, gastosVarios}
  feeBreakdown Json?

  // Fuente
  sourceDocumentId String? // DiliTrust document ID
  sourceFileName   String?

  createdAt DateTime @default(now())

  @@unique([companyId, portfolioCode, reportDate])
  @@index([companyId])
  @@index([reportDate])
  @@index([portfolioCode])
  @@map("monthly_snapshots")
}

// G8: Benchmarks — evolución de índices de referencia
model PortfolioBenchmark {
  id        String @id @default(cuid())
  companyId String

  name   String // "MSCI World Net TR EUR", "Euro Govt 3-5Yr"
  ticker String? // "MSDEWIN Index", "BERPG2 Index"
  date   DateTime // Fecha del dato

  level Float? // Nivel del índice

  returnMonth Float? // Rentabilidad mes (%)
  returnYtd   Float? // Rentabilidad YTD (%)
  return1y    Float? // Rentabilidad 1 año (%)
  return3y    Float? // Rentabilidad 3 años (%)
  return5y    Float? // Rentabilidad 5 años (%)

  createdAt DateTime @default(now())

  @@unique([companyId, name, date])
  @@index([companyId])
  @@index([date])
  @@map("portfolio_benchmarks")
}

