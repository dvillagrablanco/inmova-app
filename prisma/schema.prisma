  @@unique([requestId, providerId])
  @@index([requestId])
  @@index([providerId])
  @@map("insurance_quote_request_providers")
}

model InsuranceQuotation {
  id        String @id @default(cuid())
  companyId String

  // Referencias
  requestId  String?
  request    InsuranceQuoteRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  providerId String
  provider   InsuranceProvider      @relation(fields: [providerId], references: [id], onDelete: Cascade)

  // Datos de la cotización
  codigo        String? // Referencia del proveedor
  tipoSeguro    InsuranceType
  primaAnual    Float
  primaMensual  Float?
  sumaAsegurada Float
  franquicia    Float? // Deducible

