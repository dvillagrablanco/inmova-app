  buildingId String?
  building   Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  unitId     String?

  // Datos de la solicitud
  tipoSeguro            InsuranceType
  descripcion           String        @db.Text
  sumaAsegurada         Float?
  coberturasSolicitadas String[]      @default([])

