  fechaInicio DateTime  @default(now())
  fechaFin    DateTime?

  // Límites
  usosMaximos  Int?
  usosActuales Int  @default(0)

  // Condiciones
  condiciones String? @db.Text

  // Estado
  activo    Boolean @default(true)
  destacado Boolean @default(false)

  // CTA
