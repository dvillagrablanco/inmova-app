// ===========================
// WORKFLOWS Y AUTOMATIZACIÓN
// ===========================

enum WorkflowStatus {
  activo
  inactivo
  borrador
}

enum WorkflowTriggerType {
  manual
  evento
  programado
  webhook
}

enum WorkflowActionType {
  enviar_notificacion
  crear_tarea
  enviar_email
  ejecutar_script
  actualizar_registro
  crear_incidencia
  generar_documento
  webhook
}

// Workflow principal
model Workflow {
  id          String         @id @default(cuid())
  companyId   String
  nombre      String
  descripcion String?
  status      WorkflowStatus @default(borrador)
  version     Int            @default(1)

  // Configuración del trigger
  triggerType   WorkflowTriggerType
  triggerConfig Json // { eventType, conditions, schedule, etc }

  // Activo/Inactivo
  isActive Boolean @default(false)

  // Acciones a ejecutar
  actions WorkflowAction[]

  // Ejecuciones
  executions WorkflowExecution[]

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator User?   @relation(fields: [createdBy], references: [id])

  @@index([companyId])
  @@index([status])
  @@index([isActive])
  @@map("workflows")
}

// Acciones dentro de un workflow
model WorkflowAction {
  id         String             @id @default(cuid())
  workflowId String
  orden      Int // para ordenar las acciones
  actionType WorkflowActionType
  config     Json // configuración específica de cada acción

  // Condiciones para ejecutar esta acción
  conditions Json? // reglas opcionales

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workflowId])
  @@index([orden])
  @@map("workflow_actions")
}

// Historial de ejecuciones
model WorkflowExecution {
  id         String    @id @default(cuid())
  workflowId String
  status     String // success, failed, running
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  // Contexto de la ejecución
  triggerData Json? // datos que dispararon el workflow
  results     Json? // resultados de cada acción
  error       String? // error si falló

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([status])
  @@index([startedAt])
  @@map("workflow_executions")
}

// ========================================
