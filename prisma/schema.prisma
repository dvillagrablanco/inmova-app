model Contract {
  id                   String         @id @default(cuid())
  unitId               String
  tenantId             String
  fechaInicio          DateTime
  fechaFin             DateTime
  rentaMensual         Float
  baseImponible        Float?
  ivaPorcentaje        Float?         @default(0)
  importeIva           Float?         @default(0)
  rentaTotal           Float?
  diaPago              Int            @default(1)
  deposito             Float
  mesesFianza          Int            @default(1)
  renovacionAutomatica Boolean        @default(false)
  incrementoType       IncrementoType @default(ipc)
  incrementoValor      Float?
  gastosIncluidos      String[]       @default([])
  gastosExcluidos      String[]       @default([])
  clausulasAdicionales String?        @db.Text
  estado               ContractStatus @default(activo)
  tipo                 ContractType   @default(residencial)
  contractPdfPath      String?
  legalTemplateId      String?
  contasimpleInvoiceId String?
  isDemo               Boolean        @default(false) // Marca datos de demostración - excluir de estadísticas
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  // ==========================================
  // CAMPOS ESPECÍFICOS PARA MEDIA ESTANCIA
  // ==========================================

  // Tipo de arrendamiento según LAU
  tipoArrendamiento  TipoArrendamiento? // vivienda_habitual, temporada, vacacional, habitacion
  motivoTemporalidad MotivoTemporalidad? // trabajo, estudios, tratamiento_medico, etc.
  descripcionMotivo  String?             @db.Text // Descripción detallada del motivo

  // Duración y prorrateo
  duracionMesesPrevista  Int? // Duración prevista en meses (para alertas)
  prorrateable           Boolean @default(false) // Si se puede prorratear por días
  diasProrrateoInicio    Int? // Días a prorratear al inicio del contrato
  diasProrrateoFin       Int? // Días a prorratear al final del contrato
  importeProrrateoInicio Float? // Importe calculado del prorrateo inicial
  importeProrrateoFin    Float? // Importe calculado del prorrateo final

  // Servicios incluidos (para media estancia todo incluido)
  serviciosIncluidos  Json? // {"wifi": true, "agua": true, "luz": true, "gas": true, "limpieza": false}
  depositoSuministros Float? // Fianza adicional para suministros
  limiteConsumoLuz    Float? // Límite mensual en € (exceso a cargo inquilino)
  limiteConsumoAgua   Float? // Límite mensual en €
  limiteConsumoGas    Float? // Límite mensual en €

  // Inventario de entrada/salida
  estadoInventario       EstadoInventario? @default(pendiente)
  inventarioEntrada      Json? // Array de items con estado, fotos, observaciones
  inventarioSalida       Json? // Array de items con estado, fotos, observaciones
  fotosEntrada           String[]          @default([]) // URLs de fotos de entrada
  fotosSalida            String[]          @default([]) // URLs de fotos de salida
  fechaInventarioEntrada DateTime?
  fechaInventarioSalida  DateTime?
  incidenciasInventario  Json? // Diferencias detectadas entre entrada y salida
  importeIncidencias     Float? // Importe total de daños/incidencias

  // Condiciones específicas media estancia
  penalizacionDesistimiento Float? // % de penalización por desistimiento anticipado
  diasPreaviso              Int?    @default(30) // Días de preaviso para no renovación
  renovacionPorPeriodoIgual Boolean @default(false) // Si se renueva por mismo período
  maximasProrrogas          Int? // Número máximo de prórrogas permitidas
  prorrogasRealizadas       Int     @default(0) // Contador de prórrogas

  // Documentación específica
  documentoMotivoPath  String? // Path al documento que justifica la temporalidad
  checklistEntradaPath String? // PDF del checklist de entrada firmado
  checklistSalidaPath  String? // PDF del checklist de salida firmado

  // Campos adicionales
  codigoOperacion          String? // Código de operación (registro, etc.)
  suministrosProvisionales Float? // Importe suministros provisionales
  ibiRepercutido           Float? // IBI repercutido al inquilino (€)
  numeroContrato           String? @unique // Número legible (ej. CT-2026-0001)

  unit                  Unit                  @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenant                Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  legalTemplate         LegalTemplate?        @relation(fields: [legalTemplateId], references: [id], onDelete: SetNull)
  payments              Payment[]
  documents             Document[]
  stripeSubscription    StripeSubscription?
  morosidadPredicciones MorosidadPrediccion[]
  documentosFirma       DocumentoFirma[]

  // Fase 1
  calendarEvents CalendarEvent[]

  // Gestión de Comunidades
  depositManagement DepositManagement?

  // Nuevas funcionalidades IA (Firma Digital)
  contractSignatures        ContractSignature[]        @relation("ContractSignatures")
  operatorSignatureRequests OperatorSignatureRequest[] @relation("ContractOperatorSignatures")

  // Sociedades Inversoras
  fianzaDeposits FianzaDeposit[]

  rentUpdates RentUpdate[] @relation("ContractRentUpdates")
  guarantors  Guarantor[]  @relation("ContractGuarantors")

  @@index([tenantId, estado])
  @@index([unitId, estado])
  @@index([estado])
  @@index([fechaInicio, fechaFin])
  @@index([tenantId, fechaInicio])
  @@index([estado, fechaFin])
  @@index([unitId, fechaInicio, fechaFin])
  @@map("contracts")
}

enum StripePaymentStatus {
  pending
  processing
