  coberturas            String[] @default([])
  exclusiones           String[] @default([])
  condicionesEspeciales String?  @db.Text

  // Validez
  fechaCotizacion DateTime  @default(now())
  validaHasta     DateTime?

  // Estado
  estado       QuotationStatus @default(recibida)
  seleccionada Boolean         @default(false)

  // Documentos
  documentoUrl       String?
  documentosAdjuntos Json? // Array de {filename, url, uploadedAt}

  // Análisis IA
  analisisIA Json? // {score, pros, cons, recomendacion, riesgos}
  scoreIA    Float? // 0-100

  // Notas
  notas String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([requestId])
  @@index([providerId])
  @@index([estado])
  @@map("insurance_quotations")
}

