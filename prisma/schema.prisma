  @@index([activo])
  @@index([fechaFin])
}

/**
 * Banners promocionales del partner
 */
model PartnerBanner {
  id        String  @id @default(cuid())
  partnerId String
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  // Contenido
  titulo          String?
  subtitulo       String?
  imagenUrl       String
  imagenMobileUrl String? // Versión para móvil

