// ──────────────────────────────────────────────────────────────────────────────
// ENUMS ESPECÍFICOS DE EWOORKER
// ──────────────────────────────────────────────────────────────────────────────

enum EwoorkerTipoEmpresa {
  CONTRATISTA_PRINCIPAL // Constructor principal, gestiona obra
  SUBCONTRATISTA_N1 // Primer nivel de subcontratación
  SUBCONTRATISTA_N2 // Segundo nivel (límite legal)
  AUTONOMO // Trabajador autónomo (NO puede subcontratar)
}

enum EwoorkerPlanSuscripcion {
  OBRERO_FREE // €0/mes - Autónomos y pequeñas subcontratas
  CAPATAZ_PRO // €29-49/mes - PYMEs subcontratistas activas
  CONSTRUCTOR_ENTERPRISE // €99-149/mes - Jefes de Grupo y Constructoras
}

enum EwoorkerEstadoDocumento {
  VERDE // Todo OK, vigente >30 días
  AMARILLO // Caduca en <30 días
  ROJO // Caducado o faltante
  PENDIENTE_VALIDACION // Subido pero no verificado
}

enum EwoorkerEstadoObra {
  BORRADOR // Constructor creando la obra
  PUBLICADA // Visible para subcontratistas
  EN_LICITACION // Recibiendo ofertas
  ADJUDICADA // Subcontratista seleccionado
  EN_EJECUCION // Trabajo en curso
  COMPLETADA // Finalizada
  CANCELADA // Cancelada por el constructor
}

enum EwoorkerEstadoOferta {
  BORRADOR // Subcontratista preparando
  ENVIADA // Enviada al constructor
  VISTA // Constructor la vio
  EN_REVISION // Constructor analizando
  PRESELECCIONADA // En shortlist
  RECHAZADA // No aceptada
  ACEPTADA // Adjudicada
  RETIRADA // Cancelada por subcontratista
  EXPIRADA // Venció el plazo de validez
}

enum EwoorkerEstadoContrato {
  BORRADOR // Generándose
  PENDIENTE_FIRMA // Esperando firmas digitales
  ACTIVO // Vigente
  EN_EJECUCION // Trabajo iniciado
  COMPLETADO // Finalizado exitosamente
  CANCELADO // Cancelado por alguna parte
  EN_DISPUTA // Problema legal/económico
  RESUELTO // Disputa resuelta
}

enum EwoorkerEstadoPago {
  PENDIENTE // No pagado aún
  RETENIDO_ESCROW // Dinero en custodia de ewoorker
  LIBERADO // Autorizado para transferir
  PAGADO // Transferido al subcontratista
  CANCELADO // Pago cancelado
  EN_DISPUTA // Problema con el pago
}

enum EwoorkerTipoComision {
  SUSCRIPCION_MENSUAL // Plan de pago recurrente
  PAGO_SEGURO_ESCROW // 1.5-3% por usar escrow
  CONTRATACION_URGENTE // 5-10% trabajos urgentes
  MAQUINARIA_ON_DEMAND // 5-10% alquiler maquinaria
  SERVICIO_PREMIUM // Otros servicios
}

// ──────────────────────────────────────────────────────────────────────────────
// MODELOS PRINCIPALES
// ──────────────────────────────────────────────────────────────────────────────

// Perfil extendido de empresa para ewoorker
model EwoorkerPerfilEmpresa {
  id        String  @id @default(cuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Clasificación ewoorker
  tipoEmpresa       EwoorkerTipoEmpresa
  especialidades    String[] // ['Estructura', 'Electricidad', 'Fontanería']
  subespecialidades String[] // ['Hormigón armado', 'Domótica', 'Aerotermia']

  // Datos legales específicos construcción
  numeroREA         String? // Registro Empresas Acreditadas
  provinciaREA      String?
  fechaCaducidadREA DateTime?
  estadoREA         EwoorkerEstadoDocumento @default(PENDIENTE_VALIDACION)

  // Seguros
  numeroSeguroRC       String? // Responsabilidad Civil
  companiaSeguro       String?
  coberturaRC          Float? // Monto en €
  fechaCaducidadSeguro DateTime?
  estadoSeguro         EwoorkerEstadoDocumento @default(PENDIENTE_VALIDACION)

  // Capacidad operativa
  numeroTrabajadores Int  @default(0)
  maquinariaPropia   Json @default("[]") // Array de maquinaria
  experienciaAnios   Int  @default(0)

  // Geolocalización
  zonasOperacion   String[] // ['Madrid', 'Toledo']
  radioOperacionKm Int      @default(50)
  latitud          Float?
  longitud         Float?

  // Suscripción ewoorker
  planActual           EwoorkerPlanSuscripcion @default(OBRERO_FREE)
  fechaInicioplan      DateTime                @default(now())
  fechaProximoPago     DateTime?
  stripeCustomerId     String?                 @unique
  stripeSubscriptionId String?                 @unique

  // Ratings y reputación
  valoracionMedia        Float @default(0)
  totalReviews           Int   @default(0)
  proyectosCompletados   Int   @default(0)
  tasaCumplimientoPlazos Float @default(100) // %

  // Estado de cuenta
  disponible            Boolean   @default(true)
  verificado            Boolean   @default(false)
  fechaVerificacion     DateTime?
  destacado             Boolean   @default(false)
  motivoSuspension      String?   @db.Text
  notificacionesActivas Boolean   @default(true)

  // Portfolio
  portfolioFotos      String[] @default([])
  certificadosCalidad String[] @default([])

  // Campos adicionales perfil
  descripcion               String?  @db.Text
  telefono                  String?
  web                       String?
  logoUrl                   String?
  cif                       String?
  direccion                 String?
  codigoPostal              String?
  tipoUsuario               String? // CONTRATISTA, SUBCONTRATISTA, AMBOS
  especialidadPrincipal     String?
  especialidadesSecundarias String[] @default([])
  tarifaMediaHora           Float?
  rating                    Float    @default(0)
  activo                    Boolean  @default(true)

  // Campos de onboarding
  onboardingWelcomeCompletedAt       DateTime?
  onboardingUserTypeCompletedAt      DateTime?
  onboardingProfileCompletedAt       DateTime?
  onboardingSpecialtiesCompletedAt   DateTime?
  onboardingZonesCompletedAt         DateTime?
  onboardingPlanCompletedAt          DateTime?
  onboardingNotificationsCompletedAt DateTime?
  onboardingFirstActionCompletedAt   DateTime?
  onboardingCompletedAt              DateTime?

  // Campos de gamificación (Sprint 3)
  gamificationPoints       Int       @default(0)
  gamificationLevel        Int       @default(1)
  gamificationAchievements Json      @default("[]") // Array de IDs de logros
  loginStreak              Int       @default(0)
  lastLoginDate            DateTime?

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  ultimaActividad DateTime @default(now())

  // Relaciones ewoorker
  documentos                  EwoorkerDocumento[]
  obrasPublicadas             EwoorkerObra[]                     @relation("ObraConstructor")
  ofertasEnviadas             EwoorkerOferta[]
  contratosComoConstructor    EwoorkerContrato[]                 @relation("ContratoConstructor")
  contratosComoSubcontratista EwoorkerContrato[]                 @relation("ContratoSubcontratista")
  reviewsRecibidas            EwoorkerReview[]                   @relation("ReviewsRecibidas")
  reviewsEscritas             EwoorkerReview[]                   @relation("ReviewsEscritas")
  pagosRecibidos              EwoorkerPago[]
  certificaciones             EwoorkerCertificacion[]            @relation("CertificacionesEmpresa")
  suscripciones               EwoorkerSuscripcion[]
  trabajadores                EwoorkerTrabajador[] // Trabajadores de la empresa (modelo ewoorker original)
  verificacionSolicitudes     EwoorkerVerificacionSolicitud[]
  conversacionesParticipante  EwoorkerParticipanteConversacion[]
  puntosLog                   EwoorkerPuntosLog[]
  referralsEnviados           EwoorkerReferral[]                 @relation("ReferralsEnviados")
  referralRecibido            EwoorkerReferral?                  @relation("ReferralRecibido")

  @@index([tipoEmpresa])
  @@index([planActual])
  @@index([verificado])
  @@index([disponible])
  @@index([valoracionMedia])
  @@index([activo])
  @@map("ewoorker_perfil_empresa")
}

// Documentación legal de empresas
model EwoorkerDocumento {
  id       String                @id @default(cuid())
  perfilId String
  perfil   EwoorkerPerfilEmpresa @relation(fields: [perfilId], references: [id], onDelete: Cascade)

  // Tipo de documento
  tipo      String // 'REA', 'SEGURO_RC', 'TC1', 'TC2', 'PRL', 'CERTIFICADO_FORMACION', etc.
  categoria String // 'EMPRESA', 'TRABAJADOR', 'PRL', 'FISCAL'

  // Archivo
  nombreArchivo String
  urlArchivo    String
  tamanoBytes   Int
  mimeType      String

  // Datos extraídos por OCR
  datosExtraidos  Json? // Datos parseados del documento
  numeroDocumento String? // Número de póliza, REA, etc.
  fechaEmision    DateTime?
  fechaCaducidad  DateTime?

  // Validación
  estado                 EwoorkerEstadoDocumento @default(PENDIENTE_VALIDACION)
  validadoPor            String? // 'AUTOMATICO' | 'MANUAL' | userId
  fechaValidacion        DateTime?
  confianzaOCR           Float? // % de confianza del OCR (0-100)
  requiereRevisionManual Boolean                 @default(false)

  // Alertas
  alertaCaducidad30dias Boolean   @default(false)
  alertaCaducidad15dias Boolean   @default(false)
  alertaCaducidad7dias  Boolean   @default(false)
  fechaUltimaAlerta     DateTime?

  // Metadata
  observaciones       String? @db.Text
  version             Int     @default(1) // Si se reemplaza el documento
  documentoAnteriorId String? // Referencia al doc que reemplaza

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([perfilId])
  @@index([tipo])
  @@index([estado])
  @@index([fechaCaducidad])
  @@map("ewoorker_documento")
}

// Trabajadores individuales de una empresa (modelo ewoorker original)
// Permite ofrecer trabajadores específicos para subcontratación cuando hay baja carga
model EwoorkerTrabajador {
  id              String                @id @default(cuid())
  perfilEmpresaId String
  perfilEmpresa   EwoorkerPerfilEmpresa @relation(fields: [perfilEmpresaId], references: [id], onDelete: Cascade)

  // Datos del trabajador
  nombre                    String
  apellidos                 String?
  especialidad              String // 'Electricista', 'Soldador', 'Albañil', etc.
  especialidadesSecundarias String[] @default([])
  experienciaAnios          Int?
  descripcion               String?  @db.Text
  fotoUrl                   String?

  // Disponibilidad (core del modelo ewoorker)
  disponible         Boolean   @default(true)
  disponibleDesde    DateTime?
  disponibleHasta    DateTime?
  motivoNoDisponible String?

  // Tarifa
  tarifaHora Float?
  tarifaDia  Float?

  // Certificaciones del trabajador
  tienePRL                   Boolean   @default(false)
  fechaCaducidadPRL          DateTime?
  tieneReconocimientoMedico  Boolean   @default(false)
  fechaReconocimientoMedico  DateTime?
  certificacionesAdicionales String[]  @default([])

  // Métricas individuales
  rating              Float @default(0)
  totalReviews        Int   @default(0)
  trabajosCompletados Int   @default(0)
  tasaPuntualidad     Float @default(100) // %

  // Estado
  activo     Boolean @default(true)
  verificado Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  asignaciones EwoorkerAsignacionTrabajador[]

  @@index([perfilEmpresaId, disponible])
  @@index([especialidad, disponible])
  @@index([activo, verificado])
  @@map("ewoorker_trabajador")
}

// Asignación de trabajadores a contratos/obras
model EwoorkerAsignacionTrabajador {
  id           String             @id @default(cuid())
  trabajadorId String
  trabajador   EwoorkerTrabajador @relation(fields: [trabajadorId], references: [id], onDelete: Cascade)
  contratoId   String
  contrato     EwoorkerContrato   @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  // Período de asignación
  fechaInicio     DateTime
  fechaFin        DateTime?
  horasTrabajadas Float?

  // Estado
  estado String @default("asignado") // asignado, en_curso, completado, cancelado

  // Valoración del trabajo
  valoracion Int? // 1-5
  comentario String? @db.Text

  notas String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trabajadorId])
  @@index([contratoId])
  @@map("ewoorker_asignacion_trabajador")
}

// Obra/Proyecto publicado en el marketplace
model EwoorkerObra {
  id                  String                @id @default(cuid())
  companyId           String // Constructor principal
  company             Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  perfilConstructorId String
  perfilConstructor   EwoorkerPerfilEmpresa @relation("ObraConstructor", fields: [perfilConstructorId], references: [id])

  // Información básica
  titulo      String
  descripcion String @db.Text
  codigoObra  String @unique // Código único interno

  // Clasificación
  categoria                String // 'Estructura', 'Electricidad', etc.
  subcategorias            String[] // Más específico
  especialidadesRequeridas String[]

  // Ubicación
  provincia    String
  municipio    String
  direccion    String
  codigoPostal String?
  latitud      Float?
  longitud     Float?

  // Alcance del trabajo
  unidadesObra         Json // Array de unidades con mediciones y precios estimados
  tipoContrato         String // 'POR_UNIDADES', 'ALZADO', 'ADMINISTRACION'
  duracionEstimadaDias Int
  fechaInicioDeseada   DateTime
  fechaFinDeseada      DateTime?
  urgencia             String    @default("NORMAL") // NORMAL, ALTA, URGENTE

  // Presupuesto
  presupuestoMinimo Float?
  presupuestoMaximo Float?
  formaPago         String // 'MENSUAL', 'CERTIFICACION', 'FIN_OBRA'

  // Requisitos legales
  nivelSubcontratacionMaximo Int      @default(2) // 1 o 2 (3 excepcional)
  requiereREA                Boolean  @default(true)
  requiereSeguroRC           Boolean  @default(true)
  coberturaMinima            Float?
  certificacionesEspecificas String[] @default([])
  experienciaMinima          Int      @default(0)

  // Proceso de selección
  tipoLicitacion        String    @default("PUBLICA") // PUBLICA, PRIVADA, POR_INVITACION
  candidatosInvitados   String[]  @default([]) // IDs de perfiles invitados
  plazoRecepcionOfertas Int       @default(15) // días
  fechaCierreLicitacion DateTime?
  numeroMaximoOfertas   Int       @default(20)

  // Documentación
  planosUrls       String[] @default([])
  memoriaCalidades String?
  planSeguridad    String?
  otrosDocumentos  String[] @default([])

  // Estado
  estado            EwoorkerEstadoObra @default(BORRADOR)
  fechaPublicacion  DateTime?
  fechaAdjudicacion DateTime?
  fechaInicio       DateTime?
  fechaFin          DateTime?

  // Oferta ganadora
  ofertaAceptadaId         String? @unique
  subcontratistaAsignadoId String?

  // Metadata
  visitas        Int @default(0)
  favoritosCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  ofertas              EwoorkerOferta[]
  contrato             EwoorkerContrato?
  libroSubcontratacion EwoorkerLibroSubcontratacion?
  conversaciones       EwoorkerConversacion[]
  especialidad         String                        @default("General")

  @@index([companyId])
  @@index([perfilConstructorId])
  @@index([estado])
  @@index([categoria])
  @@index([provincia])
  @@index([especialidad])
  @@index([municipio])
  @@index([fechaPublicacion])
  @@index([urgencia])
  @@map("ewoorker_obra")
}

// Oferta de un subcontratista a una obra
model EwoorkerOferta {
  id                     String                @id @default(cuid())
  obraId                 String
  obra                   EwoorkerObra          @relation(fields: [obraId], references: [id], onDelete: Cascade)
  perfilSubcontratistaId String
  perfilSubcontratista   EwoorkerPerfilEmpresa @relation(fields: [perfilSubcontratistaId], references: [id])

  // Propuesta económica
  presupuestoTotal   Float
  desgloseManoObra   Float
  desgloseMateriales Float
  desgloseOtros      Float

  // Desglose por unidades (si aplica)
  unidadesPresupuestadas Json // Array de unidades con precio unitario

  // Forma de pago propuesta
  anticipoPorc    Float @default(20) // %
  certificaciones Json  @default("[]") // Array de certificaciones con % y descripción

  // Timing
  diasEjecucion         Int
  fechaInicioDisponible DateTime
  garantiaMeses         Int      @default(12)

  // Propuesta detallada
  descripcionDetallada String  @db.Text
  metodologia          String? @db.Text
  equipoTrabajo        Json? // Descripción del equipo asignado
  maquinariaAsignada   Json? // Maquinaria que usará
  materialesDetalle    Json? // Materiales con marca/modelo

  // Referencias
  proyectosSimilares Json @default("[]") // Referencias de trabajos anteriores
  clientesReferencia Json @default("[]") // Contactos de referencia

  // Documentación adjunta
  documentosAdjuntos String[] @default([])
  certificados       String[] @default([])
  polizaSeguro       String?

  // Estado de la oferta
  estado         EwoorkerEstadoOferta @default(ENVIADA)
  validezDias    Int                  @default(30)
  fechaEnvio     DateTime             @default(now())
  fechaVista     DateTime? // Cuando el constructor la abre
  fechaRespuesta DateTime? // Cuando se acepta/rechaza
  motivoRechazo  String?              @db.Text

  // Metadata
  esUrgente   Boolean @default(false)
  esDestacada Boolean @default(false) // Si pagó por destacar

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relación
  contrato EwoorkerContrato?

  @@unique([obraId, perfilSubcontratistaId]) // Una oferta por subcontratista por obra
  @@index([obraId])
  @@index([perfilSubcontratistaId])
  @@index([estado])
  @@index([fechaEnvio])
  @@map("ewoorker_oferta")
}

// Contrato resultante de adjudicar una obra
model EwoorkerContrato {
  id       String         @id @default(cuid())
  obraId   String         @unique
  obra     EwoorkerObra   @relation(fields: [obraId], references: [id], onDelete: Cascade)
  ofertaId String         @unique
  oferta   EwoorkerOferta @relation(fields: [ofertaId], references: [id])

  // Partes del contrato
  constructorId    String
  constructor      EwoorkerPerfilEmpresa @relation("ContratoConstructor", fields: [constructorId], references: [id])
  subcontratistaId String
  subcontratista   EwoorkerPerfilEmpresa @relation("ContratoSubcontratista", fields: [subcontratistaId], references: [id])

  // Términos económicos
  presupuestoTotal Float
  formaPago        String
  certificaciones  Json // Hitos de pago
  garantiaMeses    Int

  // Términos de ejecución
  fechaInicio        DateTime
  fechaFinEstimada   DateTime
  plazoEjecucionDias Int
  fechaFinReal       DateTime?

  // Estado del contrato
  estado   EwoorkerEstadoContrato @default(BORRADOR)
  progreso Int                    @default(0) // % de avance

  // Firmas digitales
  firmaConstructor         String? // Hash de la firma
  firmaSubcontratista      String?
  fechaFirmaConstructor    DateTime?
  fechaFirmaSubcontratista DateTime?
  ipFirmaConstructor       String?
  ipFirmaSubcontratista    String?

  // Escrow (pagos seguros)
  usaEscrow      Boolean @default(false)
  comisionEscrow Float   @default(2.5) // %

  // Metadata legal
  numeroContrato        String  @unique // Número oficial del contrato
  condicionesEspeciales String? @db.Text
  clausulasPenalizacion String? @db.Text

  // Finalización
  fechaFinalizacion DateTime?
  motivoCancelacion String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  hitos                    EwoorkerHitoContrato[]
  partesTrabajo            EwoorkerParteTrabajo[]
  certificacionesContrato  EwoorkerCertificacion[]        @relation("CertificacionesContrato")
  pagos                    EwoorkerPago[]
  incidencias              EwoorkerIncidencia[]
  changeOrders             EwoorkerChangeOrder[]
  fichajes                 EwoorkerFichaje[]
  mensajes                 EwoorkerMensajeObra[]
  reviews                  EwoorkerReview[]
  asignacionesTrabajadores EwoorkerAsignacionTrabajador[] // Trabajadores asignados al contrato
  conversaciones           EwoorkerConversacion[]
  montoTotal               Float                          @default(0)

  @@index([obraId])
  @@index([constructorId])
  @@index([subcontratistaId])
  @@index([estado])
  @@index([fechaInicio])
  @@map("ewoorker_contrato")
}

// Hitos del contrato para tracking de progreso
model EwoorkerHitoContrato {
  id         String           @id @default(cuid())
  contratoId String
  contrato   EwoorkerContrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  // Información del hito
  numero      Int // Secuencial: 1, 2, 3...
  nombre      String
  descripcion String @db.Text

  // Timing
  fechaPrevista DateTime
  fechaReal     DateTime?

  // Estado
  estado         String @default("PENDIENTE") // PENDIENTE, EN_PROGRESO, COMPLETADO, BLOQUEADO
  porcentajePeso Float // % que representa del total del proyecto

  // Validación
  aprobadoConstructor      Boolean   @default(false)
  fechaAprobacion          DateTime?
  observacionesConstructor String?   @db.Text

  // Evidencias
  fotosEvidencia     String[] @default([])
  documentosAdjuntos String[] @default([])

  // Pago asociado
  pagaAsociado Boolean @default(false)
  montoPago    Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contratoId])
  @@index([estado])
  @@index([fechaPrevista])
  @@map("ewoorker_hito_contrato")
}

// Parte de trabajo diario/semanal
model EwoorkerParteTrabajo {
  id         String           @id @default(cuid())
  contratoId String
  contrato   EwoorkerContrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  // Información básica
  fecha       DateTime
  numeroParte String // Código único del parte

  // Unidades ejecutadas
  unidadesEjecutadas Json // Array de unidades con cantidad y fotos

  // Personal empleado
  trabajadores         Json // Array de trabajadores con horas
  totalHorasTrabajadas Float

  // Maquinaria utilizada
  maquinaria Json @default("[]")

  // Materiales consumidos
  materiales Json @default("[]")

  // Incidencias del día
  incidencias Json? // Incidencias menores del día

  // Condiciones climáticas
  clima              String? // 'Soleado', 'Lluvia', 'Nieve'
  temperaturaCelsius Float?

  // Estado
  estado String @default("BORRADOR") // BORRADOR, ENVIADO, APROBADO, RECHAZADO

  // Firmas
  firmaCapataz      String?
  nombreCapataz     String?
  fechaFirmaCapataz DateTime?

  firmaJefeObra   String?
  nombreJefeObra  String?
  fechaAprobacion DateTime?
  motivoRechazo   String?   @db.Text

  // Fotos del día
  fotos String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contratoId, numeroParte])
  @@index([contratoId])
  @@index([fecha])
  @@index([estado])
  @@map("ewoorker_parte_trabajo")
}

// Certificación mensual de obra
model EwoorkerCertificacion {
  id                     String                @id @default(cuid())
  contratoId             String
  contrato               EwoorkerContrato      @relation("CertificacionesContrato", fields: [contratoId], references: [id], onDelete: Cascade)
  perfilSubcontratistaId String
  perfilSubcontratista   EwoorkerPerfilEmpresa @relation("CertificacionesEmpresa", fields: [perfilSubcontratistaId], references: [id])

  // Periodo
  mes                 Int // 1-12
  ano                 Int
  numeroCertificacion Int // Secuencial: 1, 2, 3...

  // Importes
  subtotal Float
  iva      Float
  total    Float

  // Partes de trabajo incluidos
  partesIncluidos String[] // IDs de partes de trabajo

  // Unidades certificadas
  unidadesCertificadas Json // Resumen de unidades del mes

  // Estado
  estado          String    @default("PROFORMA") // PROFORMA, APROBADA, PAGADA, RECHAZADA
  fechaAprobacion DateTime?
  fechaPago       DateTime?

  // Documentos
  pdfUrl        String?
  observaciones String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contratoId, mes, ano])
  @@index([contratoId])
  @@index([perfilSubcontratistaId])
  @@index([estado])
  @@map("ewoorker_certificacion")
}

// Pagos del sistema ewoorker
model EwoorkerPago {
  id               String                @id @default(cuid())
  contratoId       String?
  contrato         EwoorkerContrato?     @relation(fields: [contratoId], references: [id])
  perfilReceptorId String
  perfilReceptor   EwoorkerPerfilEmpresa @relation(fields: [perfilReceptorId], references: [id])

  // Tipo de pago
  tipo        EwoorkerTipoComision
  concepto    String
  descripcion String?              @db.Text

  // Importes
  montoBase          Float // Monto sobre el que se calcula
  porcentajeComision Float? // Si aplica
  montoComision      Float // Comisión de ewoorker
  montoNeto          Float // Lo que recibe el subcontratista

  // División de beneficios (50/50 con socio)
  beneficioEwoorker Float // 50% para plataforma
  beneficioSocio    Float // 50% para socio fundador

  // Estado
  estado         EwoorkerEstadoPago @default(PENDIENTE)
  fechaSolicitud DateTime           @default(now())
  fechaPago      DateTime?

  // Método de pago
  metodoPago String? // 'STRIPE', 'TRANSFERENCIA', 'ESCROW'

  // Referencias externas
  stripePaymentIntentId String? @unique
  stripeTransferId      String?
  transaccionBancoId    String?

  // Escrow
  retenidoEscrow        Boolean   @default(false)
  fechaRetencion        DateTime?
  fechaLiberacion       DateTime?
  condicionesLiberacion Json? // Condiciones para liberar

  // Metadata
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contratoId])
  @@index([perfilReceptorId])
  @@index([tipo])
  @@index([estado])
  @@index([fechaPago])
  @@map("ewoorker_pago")
}

// Fichajes con geolocalización (para app móvil)
model EwoorkerFichaje {
  id         String           @id @default(cuid())
  contratoId String
  contrato   EwoorkerContrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  // Trabajador
  nombreTrabajador String
  dniTrabajador    String
  empresaId        String // Empresa a la que pertenece

  // Tipo de fichaje
  tipo String // 'ENTRADA', 'SALIDA', 'PAUSA_INICIO', 'PAUSA_FIN'

  // Timestamp
  timestamp DateTime @default(now())
  fecha     DateTime // Solo fecha para agrupaciones
  hora      String // HH:MM

  // Geolocalización
  latitud             Float
  longitud            Float
  precisión          Float? // Precisión del GPS en metros
  dentroPerimetro     Boolean @default(true)
  distanciaObraMetros Float?

  // Verificación adicional
  fotoSelfie    String? // URL de la foto (opcional)
  dispositivoId String? // ID del dispositivo móvil
  ipAddress     String?

  // Validación documental en el momento
  documentosValidados Boolean @default(true)
  alertasDocumentales Json? // Docs caducados o próximos a caducar

  // Metadata
  observaciones String? @db.Text

  createdAt DateTime @default(now())

  @@index([contratoId])
  @@index([dniTrabajador])
  @@index([fecha])
  @@index([tipo])
  @@map("ewoorker_fichaje")
}

// Incidencias en obra
model EwoorkerIncidencia {
  id         String           @id @default(cuid())
  contratoId String
  contrato   EwoorkerContrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  // Información básica
  titulo      String
  descripcion String @db.Text
  tipo        String // 'RETRASO', 'FALTA_MATERIAL', 'CLIMA', 'SEGURIDAD', 'CALIDAD', 'OTRO'
  gravedad    String // 'BAJA', 'MEDIA', 'ALTA', 'CRITICA'

  // Reportado por
  reportadoPor     String // 'CONSTRUCTOR' | 'SUBCONTRATISTA'
  reportadorNombre String
  reportadorEmail  String?

  // Impacto
  impactoPlazo       Boolean @default(false)
  diasRetraso        Int     @default(0)
  impactoPresupuesto Boolean @default(false)
  montoAdicional     Float   @default(0)

  // Solución
  solucionPropuesta String?   @db.Text
  solucionAplicada  String?   @db.Text
  resuelta          Boolean   @default(false)
  fechaResolucion   DateTime?
  resolvidoPor      String?

  // Evidencias
  fotos              String[] @default([])
  documentosAdjuntos String[] @default([])

  // Seguimiento
  prioridad             String    @default("MEDIA") // BAJA, MEDIA, ALTA
  fechaLimite           DateTime?
  responsableResolucion String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contratoId])
  @@index([tipo])
  @@index([gravedad])
  @@index([resuelta])
  @@map("ewoorker_incidencia")
}

// Change Orders (cambios en el alcance del proyecto)
model EwoorkerChangeOrder {
  id         String           @id @default(cuid())
  contratoId String
  contrato   EwoorkerContrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  // Información del cambio
  numero        Int // Secuencial
  titulo        String
  descripcion   String @db.Text
  justificacion String @db.Text

  // Solicitado por
  solicitadoPor     String // 'CONSTRUCTOR' | 'SUBCONTRATISTA'
  solicitanteNombre String
  fechaSolicitud    DateTime @default(now())

  // Impacto económico
  impactoPresupuesto    Float // Puede ser positivo o negativo
  nuevoPresupuestoTotal Float?

  // Impacto en plazo
  impactoPlazo  Int // Días (positivo = retraso, negativo = adelanto)
  nuevaFechaFin DateTime?

  // Estado
  estado         String    @default("PENDIENTE") // PENDIENTE, APROBADO, RECHAZADO, NEGOCIANDO
  fechaRespuesta DateTime?
  respondidoPor  String?
  motivoRechazo  String?   @db.Text

  // Documentación
  planos               String[] @default([])
  presupuestoDetallado String?
  documentosAdjuntos   String[] @default([])

  // Aprobación
  aprobado        Boolean   @default(false)
  fechaAprobacion DateTime?
  firmaAprobacion String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contratoId, numero])
  @@index([contratoId])
  @@index([estado])
  @@map("ewoorker_change_order")
}

// Mensajería en obra (chat contextual)
model EwoorkerMensajeObra {
  id         String           @id @default(cuid())
  contratoId String
  contrato   EwoorkerContrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  // Remitente
  remitenteId      String // Puede ser userId o perfilId
  remitenteNombre  String
  remitenteTipo    String // 'CONSTRUCTOR' | 'SUBCONTRATISTA' | 'TECNICO'
  remitenteEmpresa String

  // Mensaje
  mensaje String @db.Text
  tipo    String @default("NORMAL") // NORMAL, NOTIFICACION_OFICIAL, ALERTA

  // Adjuntos
  adjuntos String[] @default([])

  // Contexto
  referenciaHitoId       String? // Si es sobre un hito específico
  referenciaParteId      String? // Si es sobre un parte de trabajo
  referenciaIncidenciaId String? // Si es sobre una incidencia

  // Notificación oficial (requiere acuse)
  esNotificacionOficial Boolean   @default(false)
  requiereAcuseRecibo   Boolean   @default(false)
  acuseRecibo           Boolean   @default(false)
  fechaAcuseRecibo      DateTime?
  firmante              String?

  // Estado de lectura
  leido        Boolean   @default(false)
  fechaLectura DateTime?

  // Legal
  hashIntegridad String? // SHA-256 para verificar no modificación
  exportable     Boolean @default(true) // Puede usarse como evidencia

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contratoId])
  @@index([remitenteId])
  @@index([tipo])
  @@index([createdAt])
  @@index([leido])
  @@map("ewoorker_mensaje_obra")
}

// Reviews bidireccionales
model EwoorkerReview {
  id         String           @id @default(cuid())
  contratoId String
  contrato   EwoorkerContrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  // Quién evalúa a quién
  reviewerPerfilId String
  reviewerPerfil   EwoorkerPerfilEmpresa @relation("ReviewsEscritas", fields: [reviewerPerfilId], references: [id])
  reviewedPerfilId String
  reviewedPerfil   EwoorkerPerfilEmpresa @relation("ReviewsRecibidas", fields: [reviewedPerfilId], references: [id])
  reviewerTipo     String // 'CONSTRUCTOR' | 'SUBCONTRATISTA'

  // Calificaciones generales (1-5)
  calificacionGeneral     Float
  puntualidad             Float
  calidad                 Float
  comunicacion            Float
  profesionalismo         Float
  cumplimientoPresupuesto Float

  // Si constructor evalúa a subcontratista
  cumplimientoPlazos Float?
  limpiezaObra       Float?
  seguridadTrabajo   Float?

  // Si subcontratista evalúa a constructor
  claridadRequerimientos Float?
  puntualidadPagos       Float?
  condicionesTrabajo     Float?

  // Texto
  comentario         String   @db.Text
  aspectosPositivos  String[] @default([])
  aspectosMejorables String[] @default([])
  recomendaria       Boolean

  // Evidencias
  fotos String[] @default([])

  // Metadata
