model TenantPropertyMatch {
  id        String @id @default(cuid())
  companyId String
  tenantId  String
  unitId    String

  // Scoring (0-100)
  matchScore        Int // Score total
  locationScore     Int // Proximidad a transporte, servicios
  priceScore        Int // Ajuste precio/presupuesto
