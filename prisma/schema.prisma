  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  commercialSpace CommercialSpace? @relation(fields: [commercialSpaceId], references: [id], onDelete: Cascade)
  commercialLease CommercialLease? @relation(fields: [commercialLeaseId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([commercialSpaceId])
  @@index([commercialLeaseId])
  @@index([tipo])
  @@map("commercial_documents")
}

model CommercialMaintenance {
