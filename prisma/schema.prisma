model AddOn {
  id          String @id @default(cuid())
  codigo      String @unique // "signatures_pack", "storage_pack", "ai_pack", etc.
  nombre      String // "Pack 10 Firmas", "Pack 10GB Storage", etc.
  descripcion String @db.Text
  categoria   String // "usage", "feature", "premium"

  // Precios
  precioMensual Float
  precioAnual   Float?

  // Stripe - Sincronización automática
  stripeProductId      String? // ID del producto en Stripe
  stripePriceIdMonthly String? // ID del precio mensual
  stripePriceIdAnnual  String? // ID del precio anual

  // Lo que incluye
  unidades   Int? // Ej: 10 firmas, 10 GB, 50K tokens
  tipoUnidad String? // "firmas", "GB", "tokens", "sms"

  // Disponibilidad por plan
  disponiblePara Json // ["STARTER", "PROFESSIONAL", "BUSINESS", "ENTERPRISE"]
  incluidoEn     Json? // Planes donde viene incluido gratis

  // Metadata para análisis
  margenPorcentaje Float? // Margen de beneficio
  costoUnitario    Float? // Costo real para nosotros

  // Vertical/Producto (para filtrar entre INMOVA y eWoorker)
  vertical String @default("inmova") // "inmova" o "ewoorker"

  // Estado
  activo    Boolean @default(true)
  destacado Boolean @default(false)
  orden     Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  suscripciones CompanyAddOn[]

  @@index([categoria])
  @@index([activo])
  @@index([vertical])
  @@map("addons")
}

