// ==========================================
// TIPOS ESPECÍFICOS PARA ALQUILER COMERCIAL
// (Oficinas, Locales, Naves Industriales, Coworking)
// ==========================================

enum CommercialSpaceType {
  oficina_privada // Oficina cerrada individual
  oficina_abierta // Open space / planta diáfana
  local_comercial // Local a pie de calle
  local_centro_comercial // Local en centro comercial
  nave_industrial // Nave logística/industrial
  almacen // Almacén/storage
  coworking_hot_desk // Puesto rotativo
  coworking_dedicated // Puesto fijo
  coworking_office // Oficina privada en coworking
  sala_reuniones // Sala de reuniones alquilable
  showroom // Espacio de exposición
  taller // Taller/workshop
}

enum CommercialLeaseType {
  arrendamiento_local // LAU Art. 29-35 - Uso distinto de vivienda
  arrendamiento_industria // Código Civil - Con bienes muebles
  subarrendamiento // Subalquiler autorizado
  cesion_uso // Cesión temporal de uso
  coworking_membresia // Membresía flexible
  pop_up // Alquiler temporal/pop-up
}

enum CommercialLeaseStatus {
  negociacion // En fase de negociación
  pendiente_firma // Términos acordados, pendiente firma
  activo // Contrato en vigor
  prorrogado // Contrato prorrogado automáticamente
  pre_vencimiento // A menos de 6 meses del vencimiento
  vencido // Contrato finalizado
  rescindido // Terminación anticipada
  litigio // En disputa legal
}

enum RentEscalationType {
  ipc // Según IPC publicado
  ipc_mas_diferencial // IPC + puntos adicionales
  porcentaje_fijo // % fijo anual
  importe_fijo // Cantidad fija anual
  por_facturacion // Según ventas del inquilino (retail)
  mixto_fijo_variable // Renta base + % sobre ventas
  sin_revision // Renta congelada
}

enum CommercialUsePermit {
  comercial_minorista // Retail/tiendas
  comercial_mayorista // Venta al por mayor
  hosteleria // Restauración/bares
  oficinas // Uso administrativo
  industrial_ligero // Industria ligera
  industrial_pesado // Industria pesada
  logistico // Almacenamiento/distribución
  educativo // Academias/centros formativos
  sanitario // Clínicas/consultorios
  deportivo // Gimnasios/centros deportivos
  entretenimiento // Ocio/espectáculos
  mixto // Varios usos permitidos
}

enum CommonAreaMaintenanceType {
  incluido_en_renta // CAM incluido en renta mensual
  proporcional_m2 // Según metros ocupados
  proporcional_fijo // Cuota fija mensual
  variable_real // Según gastos reales
  triple_net // Inquilino paga todo (NNN)
}

// ==========================================
// TIPOS ESPECÍFICOS PARA MEDIA ESTANCIA
// ==========================================

enum TipoArrendamiento {
  vivienda_habitual // LAU Art. 2 - Duración mínima 5 años (7 si empresa)
  temporada // LAU Art. 3.2 - Media estancia (1-11 meses)
  vacacional // Turístico (< 1 mes) - Regulación autonómica
  habitacion // Alquiler de habitación en piso compartido
}

enum MotivoTemporalidad {
  trabajo // Desplazamiento laboral temporal
  estudios // Curso académico, máster, Erasmus
  tratamiento_medico // Tratamiento médico prolongado
  proyecto_profesional // Proyecto con duración definida
  transicion // Entre compra/venta de vivienda
  turismo_extendido // Estancia turística larga (1-3 meses)
  otro // Otros motivos justificados
}

enum EstadoInventario {
  pendiente // Inventario no realizado
  entrada_completado // Inventario de entrada realizado
