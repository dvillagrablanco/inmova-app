# Coolify Environment Variables Template
# Copiar estos valores en Coolify Dashboard — NO incluir secrets reales aquí

# PostgreSQL Database
POSTGRES_DB=inmova
POSTGRES_USER=inmova
POSTGRES_PASSWORD=<CAMBIAR_POR_PASSWORD_SEGURO>

# NextAuth.js
NEXTAUTH_URL=https://www.inmova.app
NEXTAUTH_SECRET=<GENERAR: openssl rand -base64 32>

# Application
NODE_ENV=production
ENCRYPTION_KEY=<GENERAR: openssl rand -hex 32>
