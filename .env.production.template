# INMOVA Production Environment Variables
# Copiar a .env.production y rellenar con valores reales
# Variables marcadas con [REQUIRED] son obligatorias

# ── CRITICAL [REQUIRED] ──
DATABASE_URL='postgresql://USER:PASSWORD@HOST:PORT/DATABASE?connect_timeout=15&pool_timeout=15&connection_limit=10'
NEXTAUTH_SECRET='<GENERAR: openssl rand -base64 48>'
NEXTAUTH_URL='https://inmovaapp.com'
NODE_ENV=production

# ── SECURITY [REQUIRED] ──
ENCRYPTION_KEY='<GENERAR: openssl rand -hex 32>'
CRON_SECRET='<GENERAR: openssl rand -hex 32>'

# ── AWS S3 [REQUIRED for file uploads] ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_BUCKET_NAME=inmova-production

# ── Stripe [REQUIRED for payments] ──
STRIPE_SECRET_KEY='sk_live_...'
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY='pk_live_...'
STRIPE_WEBHOOK_SECRET='whsec_...'

# ── Salt Edge (Alternativa a Nordigen — Open Banking lectura movimientos) ──
# Registro sin licencia TPP: https://www.saltedge.com/partner_program
SALTEDGE_APP_ID=
SALTEDGE_SECRET=

# ── GoCardless Payments (SEPA Direct Debit — cobro alquileres) ──
GOCARDLESS_ACCESS_TOKEN=
GOCARDLESS_ENVIRONMENT=live
GOCARDLESS_WEBHOOK_SECRET=

# ── GoCardless Bank Account Data / Nordigen (DESACTIVADO nuevos registros 2025) ──
# Solo si ya tienes cuenta. Para nuevos registros usar Salt Edge.
NORDIGEN_SECRET_ID=
NORDIGEN_SECRET_KEY=

# ── Email SMTP [Configured] ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=inmovaapp@gmail.com
SMTP_PASSWORD=<app password>
SMTP_FROM='Inmova App <inmovaapp@gmail.com>'

# ── Twilio SMS [Configured] ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Anthropic Claude [Configured] ──
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Signaturit [Configured] ──
SIGNATURIT_API_KEY=
SIGNATURIT_ENVIRONMENT=production

# ── ContaSimple [Configured] ──
CONTASIMPLE_AUTH_KEY=
INMOVA_CONTASIMPLE_AUTH_KEY=

# ── Google Analytics [Configured] ──
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Sentry [Optional] ──
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Redis [Optional] ──
REDIS_URL=redis://localhost:6379

# ── Push Notifications [Optional] ──
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Application ──
NEXT_PUBLIC_APP_URL='https://inmovaapp.com'
NEXT_TELEMETRY_DISABLED=1
