# ============================================================================
# INMOVA APP - ENVIRONMENT VARIABLES
# Copiar a .env.local (desarrollo) o .env.production (producción)
# ============================================================================

# ============================================================================
# 🔴 CRÍTICAS (Required - la app no arranca sin estas)
# ============================================================================

DATABASE_URL='postgresql://user:password@localhost:5432/inmova_production'
NEXTAUTH_SECRET='<GENERAR: openssl rand -base64 48>'
NEXTAUTH_URL=http://localhost:3000

# ============================================================================
# ⚙️ APLICACIÓN
# ============================================================================

NODE_ENV=production
PORT=3000
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_APP_URL=https://inmovaapp.com
NEXT_PUBLIC_BASE_URL=https://inmovaapp.com
BASE_URL=https://inmovaapp.com

# ============================================================================
# 🔐 SEGURIDAD
# ============================================================================

ENCRYPTION_KEY=<GENERAR: openssl rand -hex 32>
CRON_SECRET=<GENERAR: openssl rand -hex 32>
MFA_ENCRYPTION_KEY=<GENERAR: openssl rand -base64 32>

# ============================================================================
# 🟡 INTEGRACIONES (Opcionales - la app funciona sin ellas)
# ============================================================================

# ── AWS S3 (Storage) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_BUCKET_NAME=inmova-production

# ── Stripe (Pagos) ──
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# ── GoCardless (SEPA + Open Banking) ──
GOCARDLESS_ACCESS_TOKEN=
GOCARDLESS_ENVIRONMENT=live
GOCARDLESS_WEBHOOK_SECRET=

# ── Bizum (Pagos instantáneos) ──
BIZUM_MERCHANT_ID=
BIZUM_SECRET_KEY=
BIZUM_BANK_PROVIDER=redsys
BIZUM_ENVIRONMENT=sandbox

# ── Email (Gmail SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=inmovaapp@gmail.com
SMTP_PASSWORD=<gmail app password>
SMTP_FROM="Inmova App <inmovaapp@gmail.com>"
EMAIL_FROM=noreply@inmovaapp.com

# ── Twilio (SMS/WhatsApp) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+34600000000

# ── Anthropic Claude (IA principal) ──
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4096

# ── OpenAI (Opcional - solo para embeddings semánticos) ──
# OPENAI_API_KEY=sk-...

# ── Signaturit (Firma Digital) ──
SIGNATURIT_API_KEY=
SIGNATURIT_ENVIRONMENT=production

# ── DocuSign (Firma Digital — Grupo Vidaro) ──
# App ID: cf89d1eb-8df4-4714-a3a5-15bb98ca873f
# Entorno actual: Demo (sandbox) → cambiar a producción cuando esté listo
# Setup: ejecutar `node scripts/setup-docusign.mjs` para configuración guiada
DOCUSIGN_INTEGRATION_KEY=cf89d1eb-8df4-4714-a3a5-15bb98ca873f
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_SECRET_KEY=
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
DOCUSIGN_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
DOCUSIGN_WEBHOOK_SECRET=

# ── ContaSimple (Contabilidad) ──
CONTASIMPLE_AUTH_KEY=
INMOVA_CONTASIMPLE_AUTH_KEY=

# ── Zucchetti/Altai (ERP) ──
# ZUCCHETTI_API_URL=
# ZUCCHETTI_CLIENT_ID=
# ZUCCHETTI_CLIENT_SECRET=

# ── Google Analytics 4 ──
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Sentry (Error Tracking) ──
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Push Notifications (VAPID) ──
# Generar: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@inmova.app

# ── Redis (Cache/Rate Limiting) ──
REDIS_URL=redis://localhost:6379

# ── Mapbox (Mapas interactivos) ──
# Dashboard: https://account.mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Slack (Notificaciones internas) ──
# Dashboard: https://api.slack.com/apps
SLACK_WEBHOOK_URL=
SLACK_CS_WEBHOOK_URL=

# ── Microsoft Clarity (Heatmaps - GRATIS) ──
# Dashboard: https://clarity.microsoft.com
NEXT_PUBLIC_CLARITY_ID=

# ── Hotjar (Heatmaps/Recordings) ──
# Dashboard: https://www.hotjar.com
NEXT_PUBLIC_HOTJAR_ID=

# ── Crisp (Live Chat) ──
# Dashboard: https://app.crisp.chat
NEXT_PUBLIC_CRISP_WEBSITE_ID=

# ── SendGrid (Email masivo - alternativa a Gmail) ──
# Dashboard: https://app.sendgrid.com
# SENDGRID_API_KEY=SG.xxx
# SENDGRID_FROM_EMAIL=noreply@inmova.app

# ── Tink (Open Banking PSD2) ──
# Dashboard: https://console.tink.com
# TINK_CLIENT_ID=
# TINK_CLIENT_SECRET=
# TINK_ENVIRONMENT=production

# ── VAPI (Voice AI Assistant) ──
# VAPI_API_KEY=
# VAPI_PRIVATE_KEY=
# VAPI_WEBHOOK_SECRET=

# ── AlertaSubastas (Subastas públicas: BOE, AEAT, SS, Notarial) ──
# Acceso: https://alertasubastas.com/login
ALERTASUBASTAS_EMAIL=
ALERTASUBASTAS_PASSWORD=

# ── Idealista Data Platform (Datos profesionales de mercado) ──
# Acceso: https://www.idealista.com/data/app/user/login
# Proporciona datos agregados de mercado con alta fiabilidad para valoraciones
IDEALISTA_DATA_EMAIL=
IDEALISTA_DATA_PASSWORD=

# ── Airbnb (Channel Manager) ──
# AIRBNB_CLIENT_ID=
# AIRBNB_CLIENT_SECRET=
# AIRBNB_ACCESS_TOKEN=
# AIRBNB_REFRESH_TOKEN=

# ============================================================================
# 🧪 TESTING
# ============================================================================

TEST_USER_EMAIL=admin@inmova.app
TEST_USER_PASSWORD=Admin123!

# ============================================================================
# 📊 DATOS EMPRESA INMOVA
# ============================================================================

INMOVA_CIF=B-19774660
INMOVA_EMAIL=inmovaapp@gmail.com
