# Run lint-staged
npx lint-staged

# Run tests for changed JS/TS files
echo "🧪 Running related tests..."
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.ts' '*.tsx' '*.js' '*.jsx')
if [ -n "$STAGED_FILES" ]; then
  npx vitest related $STAGED_FILES --run || {
    echo "❌ Tests failed. Please fix failing tests."
    exit 1
  }
else
  echo "✅ No JS/TS changes, skipping tests."
fi

echo "✅ Pre-commit checks passed!"
